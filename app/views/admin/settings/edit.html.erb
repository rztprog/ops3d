<div class="mb-8">
  <h1 class="text-3xl font-semibold text-gray-900">Paramètres</h1>
  <p class="mt-2 text-sm text-gray-500">
    Gère les réglages globaux de la boutique.
  </p>
</div>

<div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
  <div class="lg:col-span-2">
    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <% if @settings.errors.any? %>
        <div class="mb-6 rounded-xl border border-red-200 bg-red-50 p-4">
          <h2 class="text-sm font-semibold text-red-800">
            Le formulaire contient <%= pluralize(@settings.errors.count, "erreur") %>.
          </h2>

          <ul class="mt-2 list-disc pl-5 text-sm text-red-700">
            <% @settings.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <h2 class="text-lg font-semibold text-gray-900 mb-4">Frais de livraison</h2>

      <%= form_with model: @settings, url: admin_settings_path, method: :patch, local: true, class: "space-y-6" do |f| %>
        <div>
          <%= f.label :shipping_mode, "Mode de livraison", class: "block text-sm font-medium text-gray-700" %>

          <%= f.select :shipping_mode,
            [
              ["Livraison gratuite", "free"],
              ["Forfait fixe", "flat_rate"]
            ],
            {},
            class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>

          <p class="mt-2 text-xs text-gray-500">
            Choisis si la livraison est gratuite ou facturée avec un montant fixe.
          </p>
        </div>

        <div>
          <%= f.label :shipping_price_euros, "Montant du forfait livraison (€)", class: "block text-sm font-medium text-gray-700" %>

          <%= f.text_field :shipping_price_euros,
            value: number_with_precision(@settings.shipping_price_euros, precision: 2),
            inputmode: "decimal",
            class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>

          <p class="mt-2 text-xs text-gray-500">
            Exemple : 4.90. Ce montant sera stocké en centimes en base.
          </p>
        </div>

        <div class="flex items-center gap-3 pt-2">
          <%= f.submit "Enregistrer les paramètres",
            class: "rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700 cursor-pointer" %>

          <%= link_to "Retour admin",
            admin_root_path,
            class: "rounded-xl border border-gray-300 px-5 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
        </div>
      <% end %>
    </div>
  </div>

  <div>
    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-gray-900">Aperçu actuel</h2>

      <dl class="mt-4 space-y-4 text-sm">
        <div class="flex items-center justify-between gap-4">
          <dt class="text-gray-500">Mode</dt>
          <dd class="font-medium text-gray-900">
            <%= @settings.shipping_mode == "free" ? "Gratuite" : "Forfait fixe" %>
          </dd>
        </div>

        <div class="flex items-center justify-between gap-4">
          <dt class="text-gray-500">Montant</dt>
          <dd class="font-medium text-gray-900">
            <%= @settings.shipping_mode == "free" ? "€0.00" : number_to_currency(@settings.shipping_price_cents / 100.0, unit: "€") %>
          </dd>
        </div>
      </dl>

      <div class="mt-6 rounded-xl bg-gray-50 p-4 text-sm text-gray-600">
        Les nouvelles commandes utiliseront ces paramètres. Les anciennes commandes gardent leur montant de livraison historique.
      </div>
    </div>
  </div>
</div>

<div class="mt-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
  <h2 class="text-lg font-semibold text-gray-900 mb-4">Codes promo</h2>
  <p class="mt-1 text-sm text-gray-500">
    Crée des réductions fixes appliquées au panier.
  </p>

  <%= form_with model: [:admin, @promo_code], local: true, class: "mt-6 grid grid-cols-1 gap-4 md:grid-cols-3" do |f| %>
    <div>
      <%= f.label :code, "Code", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :code,
        placeholder: "FREE",
        class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
    </div>

    <div>
      <%= f.label :discount_cents, "Réduction (€)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :discount_euros,
        name: "promo_code[discount_euros]",
        placeholder: "2.50",
        class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
    </div>

    <label class="mt-8 flex items-center gap-2 text-sm text-gray-700">
      <%= f.check_box :active, checked: true, class: "rounded border-gray-300" %>
      Actif
    </label>

    <div class="md:col-span-3">
      <%= f.submit "Créer le code promo",
        class: "cursor-pointer rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>
    </div>
  <% end %>

  <div class="mt-6 space-y-3">
    <% @promo_codes.each do |promo| %>
      <div class="flex items-center justify-between rounded-xl border border-gray-200 px-4 py-3 text-sm">
        <div>
          <p class="font-semibold text-gray-900"><%= promo.code %></p>
          <p class="text-gray-500">
            <%= number_to_currency(promo.discount_cents / 100.0, unit: "€") %>
            · <%= promo.active? ? "Actif" : "Inactif" %>
          </p>
        </div>

        <%= button_to "Supprimer",
          admin_promo_code_path(promo),
          method: :delete,
          form: { data: { turbo_confirm: "Supprimer ce code promo ?" } },
          class: "text-sm font-medium text-red-600 hover:text-red-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
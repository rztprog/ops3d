<div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
  <% if @category.errors.any? %>
    <div class="mb-6 rounded-xl border border-red-200 bg-red-50 p-4">
      <h2 class="text-sm font-semibold text-red-800">
        Le formulaire contient <%= pluralize(@category.errors.count, "erreur") %>.
      </h2>

      <ul class="mt-2 list-disc pl-5 text-sm text-red-700">
        <% @category.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: [:admin, @category], local: true, class: "space-y-6" do |f| %>
    <div>
      <%= f.label :name, "Nom de la catégorie", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit class: "rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>

      <%= link_to "Annuler",
        admin_categories_path,
        class: "rounded-xl border border-gray-300 px-5 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    </div>
  <% end %>
</div>
<div class="mb-8 flex items-start justify-between gap-4">
  <div>
    <h1 class="text-3xl font-bold text-gray-900"><%= @category.name %></h1>
    <p class="mt-2 text-sm text-gray-500">
      Détail de la catégorie dans l’admin.
    </p>
  </div>

  <div class="flex items-center gap-3">
    <%= link_to "Modifier",
      edit_admin_category_path(@category),
      class: "rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>

    <%= button_to "Supprimer",
      admin_category_path(@category),
      method: :delete,
      data: { turbo_confirm: "Supprimer cette catégorie ?" },
      class: "rounded-xl border border-red-300 px-5 py-3 text-sm font-medium text-red-700 hover:bg-red-50" %>
  </div>
</div>

<div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
  <dl class="space-y-4 text-sm">
    <div class="flex items-center justify-between gap-4">
      <dt class="text-gray-500">Nom</dt>
      <dd class="font-medium text-gray-900"><%= @category.name %></dd>
    </div>

    <div class="flex items-center justify-between gap-4">
      <dt class="text-gray-500">Nombre de produits</dt>
      <dd class="font-medium text-gray-900"><%= @category.products.count %></dd>
    </div>
  </dl>
</div>
<div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Catégories</h1>
    <p class="mt-2 text-sm text-gray-500">
      Gère les catégories de ton catalogue.
    </p>
  </div>

  <%= link_to "Nouvelle catégorie",
    new_admin_category_path,
    class: "inline-flex w-full items-center justify-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700 sm:w-auto" %>
</div>

<% if @categories.empty? %>
  <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
    <h2 class="text-xl font-semibold text-gray-900">Aucune catégorie</h2>
    <p class="mt-2 text-gray-500">Commence par créer ta première catégorie.</p>
  </div>
<% else %>

  <!-- DESKTOP TABLE -->
  <div class="hidden overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm lg:block">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Nom</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Produits liés</th>
          <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Actions</th>
        </tr>
      </thead>

      <tbody class="divide-y divide-gray-200 bg-white">
        <% @categories.each do |category| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <p class="font-medium text-gray-900"><%= category.name %></p>
            </td>

            <td class="px-6 py-4 text-sm text-gray-600">
              <%= pluralize(category.products.count, "produit") %>
            </td>

            <td class="px-6 py-4">
              <div class="flex items-center justify-end gap-3">
                <%= link_to "Voir",
                  admin_category_path(category),
                  class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>

                <%= link_to "Modifier",
                  edit_admin_category_path(category),
                  class: "text-sm font-medium text-indigo-600 hover:text-indigo-800" %>

                <%= button_to "Supprimer",
                  admin_category_path(category),
                  method: :delete,
                  data: { turbo_confirm: "Supprimer cette catégorie ?" },
                  class: "text-sm font-medium text-red-600 hover:text-red-800" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- MOBILE CARDS -->
  <div class="space-y-4 lg:hidden">
    <% @categories.each do |category| %>
      <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
        <%= link_to admin_category_path(category), class: "block p-5 hover:bg-gray-50" do %>
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-lg font-semibold text-gray-900">
                <%= category.name %>
              </p>

              <p class="mt-2 text-sm text-gray-500">
                <%= pluralize(category.products.count, "produit lié") %>
              </p>
            </div>

            <i class="fa-solid fa-chevron-right mt-1 text-xs text-gray-400"></i>
          </div>
        <% end %>

        <div class="grid grid-cols-2 divide-x divide-gray-200 border-t border-gray-200">
          <%= link_to "Modifier",
            edit_admin_category_path(category),
            class: "px-4 py-3 text-center text-sm font-medium text-indigo-600 hover:bg-gray-50" %>

          <%= button_to "Supprimer",
            admin_category_path(category),
            method: :delete,
            data: { turbo_confirm: "Supprimer cette catégorie ?" },
            form_class: "contents",
            class: "w-full px-4 py-3 text-center text-sm font-medium text-red-600 hover:bg-gray-50" %>
        </div>
      </div>
    <% end %>
  </div>
  
<% end %>
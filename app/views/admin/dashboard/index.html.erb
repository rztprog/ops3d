<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Dashboard admin</h1>
  <p class="mt-2 text-sm text-gray-500">
    Vue d'ensemble de l'activité OPS3D.
  </p>
</div>

<!-- Navigation cards -->
<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-4">
  <%= link_to admin_products_path, class: "rounded-2xl border border-[color:var(--light)] hover:border-blue-500 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" do %>
    <p class="text-sm text-gray-500">Produits</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @products_count %></p>
  <% end %>

  <%= link_to admin_categories_path, class: "rounded-2xl border border-[color:var(--light)] hover:border-blue-500 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" do %>
    <p class="text-sm text-gray-500">Catégories</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @categories_count %></p>
  <% end %>

  <%= link_to admin_orders_path, class: "rounded-2xl border border-[color:var(--light)] hover:border-blue-500 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" do %>
    <p class="text-sm text-gray-500">Commandes</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @orders_count %></p>
  <% end %>

  <%= link_to admin_users_path, class: "rounded-2xl border border-[color:var(--light)] hover:border-blue-500 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" do %>
    <p class="text-sm text-gray-500">Utilisateurs</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @users_count %></p>
  <% end %>
</div>

<!-- Business KPIs -->
<div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <p class="text-sm text-gray-500">CA aujourd'hui</p>
    <p class="mt-2 text-3xl font-bold text-gray-900">
      <%= number_to_currency(@today_revenue_cents / 100.0, unit: "€") %>
    </p>
  </div>

  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <p class="text-sm text-gray-500">CA 7 derniers jours</p>
    <p class="mt-2 text-3xl font-bold text-gray-900">
      <%= number_to_currency(@week_revenue_cents / 100.0, unit: "€") %>
    </p>
  </div>

  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <p class="text-sm text-gray-500">Commandes payées</p>
    <p class="mt-2 text-3xl font-bold text-gray-900">
      <%= @paid_orders_count %>
    </p>
  </div>

  <%= link_to admin_orders_path, class: "rounded-2xl border border-lime-300 hover:border-green-300 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" do %>
    <p class="text-sm text-gray-500">À traiter</p>
    <p class="mt-2 text-3xl font-bold text-gray-900">
      <%= @orders_to_process_count %>
    </p>
  <% end %>
</div>

<div class="mt-8 grid grid-cols-1 gap-8 xl:grid-cols-3">
  <!-- Chart -->
  <div class="xl:col-span-2 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <div class="mb-6 flex items-center justify-between">
      <div>
        <h2 class="text-lg font-semibold text-gray-900">Ventes sur 7 jours</h2>
        <p class="mt-1 text-sm text-gray-500">Commandes payées uniquement.</p>
      </div>
    </div>

    <div class="flex h-64 items-end gap-4 border-b border-gray-200 pb-4">
      <% @sales_by_day.each do |day| %>
        <% height = @max_sales_cents.positive? ? ((day[:total_cents].to_f / @max_sales_cents) * 100).round : 0 %>

        <div class="flex flex-1 flex-col items-center gap-3">
          <div class="flex h-48 w-full items-end justify-center">
            <div
              class="w-full max-w-12 rounded-t-xl bg-[color:var(--dark)] transition hover:bg-[color:var(--light)]"
              style="height: <%= [height, 4].max %>%;">
            </div>
          </div>

          <div class="text-center">
            <p class="text-xs font-medium text-gray-700">
              <%= day[:label] %>
            </p>
            <p class="mt-1 text-xs text-gray-500">
              <%= number_to_currency(day[:total_cents] / 100.0, unit: "€") %>
            </p>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent orders -->
  <div class="rounded-2xl border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-200 px-6 py-4">
      <h2 class="text-lg font-semibold text-gray-900">Dernières commandes</h2>
    </div>

    <% if @recent_orders.any? %>
      <div class="divide-y divide-gray-200">
        <% @recent_orders.each do |order| %>
          <%= link_to admin_order_path(order), class: "block px-6 py-4 hover:bg-gray-50" do %>
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-medium text-gray-900">Commande #<%= order.id %></p>
                <p class="mt-1 text-sm text-gray-500">
                  <%= order.email %>
                </p>
              </div>

              <span class="rounded-full px-3 py-1 text-xs font-medium <%= order_status_badge_class(order.status) %>">
                <%= order_status_label(order.status) %>
              </span>
            </div>

            <div class="mt-3 flex items-center justify-between text-sm">
              <span class="text-gray-500">
                <%= l(order.created_at, format: :short) %>
              </span>

              <span class="font-medium text-gray-900">
                <%= number_to_currency(order.total_price_cents / 100.0, unit: "€") %>
              </span>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-10 text-center">
        <p class="text-sm text-gray-500">Aucune commande pour le moment.</p>
      </div>
    <% end %>
  </div>
</div>
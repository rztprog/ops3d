<div class="mb-8">
  <h1 class="text-3xl font-bold text-gray-900">Dashboard admin</h1>
  <p class="mt-2 text-sm text-gray-500">
    Vue d'ensemble de ton activité et de ton catalogue.
  </p>
</div>

<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-4">
  <%= link_to admin_products_path, class: "rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" do %>
    <p class="text-sm text-gray-500">Produits</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @products_count %></p>
  <% end %>

  <%= link_to admin_categories_path, class: "rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" do %>
    <p class="text-sm text-gray-500">Catégories</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @categories_count %></p>
  <% end %>

  <%= link_to admin_orders_path, class: "rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" do %>
    <p class="text-sm text-gray-500">Commandes</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @orders_count %></p>
  <% end %>

  <%= link_to admin_users_path, class: "rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" do %>
    <p class="text-sm text-gray-500">Utilisateurs</p>
    <p class="mt-2 text-3xl font-bold text-gray-900"><%= @users_count %></p>
  <% end %>
</div>
<div class="mb-8 flex items-end justify-between gap-4">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Commandes</h1>
    <p class="mt-2 text-sm text-gray-500">
      Suis et gère les commandes clients.
    </p>
  </div>

  <p class="text-sm text-gray-500">
    <%= pluralize(@orders.count, "commande", plural: 'commandes') %>
  </p>
</div>

<% if @orders.empty? %>
  <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
    <h2 class="text-xl font-semibold text-gray-900">Aucune commande</h2>
    <p class="mt-2 text-gray-500">Les commandes apparaîtront ici.</p>
  </div>
<% else %>
  <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Commande</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Client</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Montant</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Statut</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Date</th>
          <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Actions</th>
        </tr>
      </thead>

      <tbody class="divide-y divide-gray-200 bg-white">
        <% @orders.each do |order| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <p class="font-medium text-gray-900">Commande #<%= order.id %></p>
              <p class="text-sm text-gray-500">
                <%= pluralize(order.order_items.sum(&:quantity), "article") %>
              </p>
            </td>

            <td class="px-6 py-4">
              <p class="text-sm font-medium text-gray-900">
                <%= [order.first_name, order.last_name].join(" ") %>
              </p>
              <p class="text-sm text-gray-500"><%= order.email %></p>
            </td>

            <td class="px-6 py-4 text-sm font-medium text-gray-900">
              <%= number_to_currency(order.total_price_cents / 100.0, unit: "€") %>
            </td>

            <td class="px-6 py-4 text-sm">
              <span class="rounded-full px-3 py-1 text-xs font-medium <%= order_status_badge_class(order.status) %>">
                <%= order_status_label(order.status) %>
              </span>
            </td>

            <td class="px-6 py-4 text-sm text-gray-600">
              <%= l(order.created_at, format: :short) %>
            </td>

            <td class="px-6 py-4 text-right">
              <%= link_to "Voir",
                admin_order_path(order),
                class: "text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
<div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Commandes</h1>
    <p class="mt-2 text-sm text-gray-500">
      Suis et gère les commandes clients.
    </p>
  </div>

  <p class="text-sm font-medium text-gray-500">
    <%= pluralize(@orders.count, "commande", plural: "commandes") %>
  </p>
</div>

<% if @orders.empty? %>
  <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
    <h2 class="text-xl font-semibold text-gray-900">Aucune commande</h2>
    <p class="mt-2 text-gray-500">Les commandes apparaîtront ici.</p>
  </div>
<% else %>
  <!-- DESKTOP TABLE -->
  <div class="hidden overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm lg:block">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Commande</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Client</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Montant</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Statut</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Date</th>
          <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Actions</th>
        </tr>
      </thead>

      <tbody class="divide-y divide-gray-200 bg-white">
        <% @orders.each do |order| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <p class="font-medium text-gray-900">Commande #<%= order.id %></p>
              <p class="text-sm text-gray-500">
                <%= pluralize(order.order_items.sum(&:quantity), "article") %>
              </p>
            </td>

            <td class="px-6 py-4">
              <p class="text-sm font-medium text-gray-900">
                <%= [order.first_name, order.last_name].join(" ") %>
              </p>
              <p class="text-sm text-gray-500"><%= order.email %></p>
            </td>

            <td class="px-6 py-4 text-sm font-medium text-gray-900">
              <%= number_to_currency(order.total_price_cents / 100.0, unit: "€") %>
            </td>

            <td class="px-6 py-4 text-sm">
              <span class="rounded-full px-3 py-1 text-xs font-medium <%= order_status_badge_class(order.status) %>">
                <%= order_status_label(order.status) %>
              </span>
            </td>

            <td class="px-6 py-4 text-sm text-gray-600">
              <%= l(order.created_at, format: :short) %>
            </td>

            <td class="px-6 py-4 text-right">
              <%= link_to "Voir",
                admin_order_path(order),
                class: "text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- MOBILE CARDS -->
  <div class="space-y-4 lg:hidden">
    <% @orders.each do |order| %>
      <%= link_to admin_order_path(order),
        class: "block rounded-2xl border border-gray-200 bg-white p-5 shadow-sm transition hover:bg-gray-50" do %>

        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="font-semibold text-gray-900">
              Commande #<%= order.id %>
            </p>

            <p class="mt-1 text-sm text-gray-500">
              <%= pluralize(order.order_items.sum(&:quantity), "article") %>
            </p>
          </div>

          <span class="rounded-full px-3 py-1 text-xs font-medium <%= order_status_badge_class(order.status) %>">
            <%= order_status_label(order.status) %>
          </span>
        </div>

        <div class="mt-4">
          <p class="text-sm font-medium text-gray-900">
            <%= [order.first_name, order.last_name].join(" ") %>
          </p>
          <p class="mt-1 truncate text-sm text-gray-500">
            <%= order.email %>
          </p>
        </div>

        <div class="mt-5 flex items-center justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-wide text-gray-400">Montant</p>
            <p class="mt-1 text-lg font-black text-gray-900">
              <%= number_to_currency(order.total_price_cents / 100.0, unit: "€") %>
            </p>
          </div>

          <div class="text-right">
            <p class="text-xs uppercase tracking-wide text-gray-400">Date</p>
            <p class="mt-1 text-sm font-medium text-gray-700">
              <%= l(order.created_at, format: :short) %>
            </p>
          </div>
        </div>

        <div class="mt-4 flex items-center justify-end text-gray-400">
          <i class="fa-solid fa-chevron-right text-xs"></i>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
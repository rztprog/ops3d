<div class="mb-8 flex items-start justify-between gap-4">
  <div>
    <h1 class="text-3xl font-bold text-gray-900"><%= @product.name %></h1>
    <p class="mt-2 text-sm text-gray-500">
      Détail du produit dans l’admin.
    </p>
  </div>

  <div class="flex items-center gap-3">
    <%= link_to "Modifier",
      edit_admin_product_path(@product),
      class: "rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>

    <%= button_to "Supprimer",
      admin_product_path(@product),
      method: :delete,
      data: { turbo_confirm: "Supprimer ce produit ?" },
      class: "rounded-xl border border-red-300 px-5 py-3 text-sm font-medium text-red-700 hover:bg-red-50" %>
  </div>
</div>

<div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
  <div>
    <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
      <% if @product.images.attached? %>
        <%= image_tag @product.images.first, class: "h-full w-full object-cover" %>
      <% else %>
        <div class="flex aspect-square items-center justify-center bg-gray-100 text-sm text-gray-400">
          Pas d'image
        </div>
      <% end %>
    </div>

    <% if @product.images.attached? && @product.images.size > 1 %>
      <div class="mt-4 grid grid-cols-4 gap-3">
        <% @product.images.each do |image| %>
          <div class="overflow-hidden rounded-xl border border-gray-200 bg-white">
            <%= image_tag image, class: "aspect-square h-full w-full object-cover" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="space-y-6">
    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-gray-900">Informations</h2>

      <dl class="mt-4 space-y-4 text-sm">
        <div class="flex items-center justify-between gap-4">
          <dt class="text-gray-500">Catégorie</dt>
          <dd class="font-medium text-gray-900"><%= @product.category&.name %></dd>
        </div>

        <div class="flex items-center justify-between gap-4">
          <dt class="text-gray-500">Prix</dt>
          <dd class="font-medium text-gray-900"><%= number_to_currency(@product.price_cents / 100.0, unit: "€") %></dd>
        </div>

        <div class="flex items-center justify-between gap-4">
          <dt class="text-gray-500">Publié</dt>
          <dd class="font-medium text-gray-900"><%= @product.published? ? "Oui" : "Non" %></dd>
        </div>

        <div class="flex items-center justify-between gap-4">
          <dt class="text-gray-500">Disponible</dt>
          <dd class="font-medium text-gray-900"><%= @product.available? ? "Oui" : "Non" %></dd>
        </div>
      </dl>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-gray-900">Description</h2>
      <div class="mt-4 text-sm leading-6 text-gray-600">
        <%= simple_format(@product.description) %>
      </div>
    </div>
  </div>
</div>
<div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Produits</h1>
    <p class="mt-2 text-sm text-gray-500">
      Gère le catalogue de tes pièces 3D.
    </p>
  </div>

  <%= link_to "Nouveau produit",
    new_admin_product_path,
    class: "inline-flex w-full items-center justify-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700 sm:w-auto" %>
</div>

<% if @products.empty? %>
  <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
    <h2 class="text-xl font-semibold text-gray-900">Aucun produit</h2>
    <p class="mt-2 text-gray-500">Commence par créer ton premier produit.</p>

    <div class="mt-6">
      <%= link_to "Créer un produit",
        new_admin_product_path,
        class: "inline-flex items-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>
    </div>
  </div>
<% else %>
  <!-- DESKTOP TABLE -->
  <div class="hidden overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm lg:block">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Produit</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Catégorie</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Prix</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Publié</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Disponible</th>
          <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Actions</th>
        </tr>
      </thead>

      <tbody class="divide-y divide-gray-200 bg-white">
        <% @products.each do |product| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <div class="flex items-center gap-4">
                <div class="h-14 w-14 overflow-hidden rounded-xl bg-gray-100">
                  <% if product.images.attached? %>
                    <%= image_tag product.images.first, class: "h-full w-full object-cover" %>
                  <% end %>
                </div>

                <div>
                  <p class="font-medium text-gray-900"><%= product.name %></p>
                  <p class="text-sm text-gray-500">
                    <%= truncate(product.description.to_s, length: 60) %>
                  </p>
                </div>
              </div>
            </td>

            <td class="px-6 py-4 text-sm text-gray-700">
              <%= product.category&.name || "—" %>
            </td>

            <td class="px-6 py-4 text-sm font-medium text-gray-900">
              <%= number_to_currency(product.price_cents / 100.0, unit: "€") %>
            </td>

            <td class="px-6 py-4 text-sm">
              <% if product.published? %>
                <span class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700">Oui</span>
              <% else %>
                <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600">Non</span>
              <% end %>
            </td>

            <td class="px-6 py-4 text-sm">
              <% if product.available? %>
                <span class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700">Oui</span>
              <% else %>
                <span class="rounded-full bg-red-100 px-3 py-1 text-xs font-medium text-red-700">Non</span>
              <% end %>
            </td>

            <td class="px-6 py-4">
              <div class="flex items-center justify-end gap-3">
                <%= link_to "Voir", admin_product_path(product), class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
                <%= link_to "Modifier", edit_admin_product_path(product), class: "text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
                <%= button_to "Supprimer",
                  admin_product_path(product),
                  method: :delete,
                  data: { turbo_confirm: "Supprimer ce produit ?" },
                  class: "text-sm font-medium text-red-600 hover:text-red-800" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- MOBILE CARDS -->
  <div class="space-y-4 lg:hidden">
    <% @products.each do |product| %>
      <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
        <%= link_to admin_product_path(product), class: "block p-4 hover:bg-gray-50" do %>
          <div class="flex gap-4">
            <div class="h-20 w-20 shrink-0 overflow-hidden rounded-xl bg-gray-100">
              <% if product.images.attached? %>
                <%= image_tag product.images.first, class: "h-full w-full object-cover" %>
              <% else %>
                <div class="flex h-full w-full items-center justify-center text-xs text-gray-400">
                  —
                </div>
              <% end %>
            </div>

            <div class="min-w-0 flex-1">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <p class="truncate font-semibold text-gray-900"><%= product.name %></p>
                  <p class="mt-1 text-xs uppercase tracking-wide text-gray-400">
                    <%= product.category&.name || "Sans catégorie" %>
                  </p>
                </div>

                <i class="fa-solid fa-chevron-right mt-1 text-xs text-gray-400"></i>
              </div>

              <p class="mt-2 line-clamp-2 text-sm leading-6 text-gray-500">
                <%= truncate(product.description.to_s, length: 90) %>
              </p>

              <div class="mt-4 flex items-center justify-between gap-3">
                <p class="text-lg font-black text-gray-900">
                  <%= number_to_currency(product.price_cents / 100.0, unit: "€") %>
                </p>

                <div class="flex flex-wrap justify-end gap-2">
                  <% if product.published? %>
                    <span class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700">Publié</span>
                  <% else %>
                    <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600">Non publié</span>
                  <% end %>

                  <% if product.available? %>
                    <span class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700">Dispo</span>
                  <% else %>
                    <span class="rounded-full bg-red-100 px-3 py-1 text-xs font-medium text-red-700">Indispo</span>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <div class="grid grid-cols-2 divide-x divide-gray-200 border-t border-gray-200">
          <%= link_to "Modifier",
            edit_admin_product_path(product),
            class: "px-4 py-3 text-center text-sm font-medium text-indigo-600 hover:bg-gray-50" %>

          <%= button_to "Supprimer",
            admin_product_path(product),
            method: :delete,
            data: { turbo_confirm: "Supprimer ce produit ?" },
            form_class: "contents",
            class: "w-full px-4 py-3 text-center text-sm font-medium text-red-600 hover:bg-gray-50" %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
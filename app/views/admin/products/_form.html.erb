<div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
  <% if @product.errors.any? %>
    <div class="mb-6 rounded-xl border border-red-200 bg-red-50 p-4">
      <h2 class="text-sm font-semibold text-red-800">
        Le formulaire contient <%= pluralize(@product.errors.count, "erreur") %>.
      </h2>

      <ul class="mt-2 list-disc pl-5 text-sm text-red-700">
        <% @product.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: [:admin, @product], local: true, class: "space-y-6" do |f| %>
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <div class="md:col-span-2">
        <%= f.label :name, "Nom du produit", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :name, class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
      </div>

      <span class="block text-sm font-medium text-gray-700 -mb-5">Fonctionnalités</span>
      <%# Wrapper  %>
      <div class="md:col-span-2 grid grid-cols-1 items-start gap-6 lg:grid-cols-2">

        <%# Champs personnalisés %>
        <% custom_fields_count = @product.product_custom_fields.reject(&:new_record?).count %>
        <div class="self-start min-h-[120px] rounded-2xl border border-gray-700 bg-gray-200 p-6 shadow-sm" data-controller="toggle-section">          
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900">Champs personnalisés</h2>
              <p class="mt-1 text-sm text-gray-500">
                Ajoute les informations spécifiques à demander au client pour ce produit.
              </p>
            </div>

            <button
              type="button"
              data-action="click->toggle-section#toggle"
              class="min-h-[70px] relative cursor-pointer gap-2 inline-flex w-full items-center justify-center rounded-xl border border-gray-300 px-4 py-3 text-sm font-medium text-gray-700 bg-[color:var(--dark)] text-white hover:bg-[color:var(--light)] sm:w-auto">
              <span>Configurer les champs</span>

              <% if custom_fields_count.positive? %>
                <span class="absolute -top-2.5 -right-2.5 flex h-7 w-7 items-center justify-center rounded-full bg-green-600 text-md font-semibold text-white">
                  <%= custom_fields_count %>
                </span>
              <% end %>
            </button>
          </div>

          <div data-toggle-section-target="content" class="mt-6 space-y-5 hidden">
            <%= f.fields_for :product_custom_fields do |field_form| %>
              <div class="rounded-xl border border-gray-200 bg-gray-50 p-4">
                <%= field_form.hidden_field :id %>

                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                  <div>
                    <%= field_form.label :label, "Nom du champ", class: "block text-sm font-medium text-gray-700" %>
                    <%= field_form.text_field :label,
                      placeholder: "Ex : NIGEND, Numéro RIO, Service / Unité",
                      class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
                  </div>

                  <div>
                    <%= field_form.label :field_type, "Type", class: "block text-sm font-medium text-gray-700" %>
                    <%= field_form.select :field_type,
                      ProductCustomField::FIELD_TYPES.map { |type| [type.humanize, type] },
                      {},
                      class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
                  </div>

                  <div>
                    <%= field_form.label :placeholder, "Placeholder", class: "block text-sm font-medium text-gray-700" %>
                    <%= field_form.text_field :placeholder,
                      placeholder: "Ex : 8850261",
                      class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
                  </div>

                  <div>
                    <%= field_form.label :position, "Position", class: "block text-sm font-medium text-gray-700" %>
                    <%= field_form.number_field :position,
                      min: 0,
                      class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
                  </div>
                </div>

                <div class="mt-4 flex flex-wrap items-center gap-6">
                  <label class="flex items-center gap-2 text-sm text-gray-700">
                    <%= field_form.check_box :required,
                      class: "rounded border-gray-300 text-gray-900 focus:ring-gray-900" %>
                    Obligatoire
                  </label>

                  <% if field_form.object.persisted? %>
                    <label class="flex items-center gap-2 text-sm text-red-600">
                      <%= field_form.check_box :_destroy,
                        class: "rounded border-gray-300 text-red-600 focus:ring-red-600" %>
                      Supprimer ce champ
                    </label>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <%# Prix degressif %>
        <% quantity_prices_count = @product.product_quantity_prices.reject(&:new_record?).count %>
        <div class="self-start min-h-[120px] rounded-2xl border border-gray-700 bg-gray-200 p-6 shadow-sm" data-controller="toggle-section">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900">
                Prix dégressifs
              </h2>

              <p class="mt-1 text-sm text-gray-500">
                Ajoute un prix unitaire réduit à partir d'une quantité donnée.
              </p>
            </div>

            <button
              type="button"
              data-action="click->toggle-section#toggle"
              class="min-h-[70px] relative cursor-pointer inline-flex w-full items-center justify-center gap-2 rounded-xl border border-gray-300 bg-[color:var(--dark)] px-4 py-3 text-sm font-medium text-white hover:bg-[color:var(--light)] sm:w-auto">
              <span>Configurer les prix</span>

              <% if quantity_prices_count.positive? %>
                <span class="absolute -top-2.5 -right-2.5 flex h-7 w-7 items-center justify-center rounded-full bg-green-600 text-md font-semibold text-white">
                  <%= quantity_prices_count %>
                </span>
              <% end %>
            </button>
          </div>

          <div data-toggle-section-target="content" class="mt-6 space-y-5 hidden">
            <%= f.fields_for :product_quantity_prices do |price_form| %>
              <div class="grid grid-cols-1 gap-4 rounded-xl border border-gray-200 bg-white p-4 md:grid-cols-3">
                <%= price_form.hidden_field :id %>

                <div>
                  <%= price_form.label :min_quantity, "À partir de", class: "block text-sm font-medium text-gray-700" %>
                  <%= price_form.number_field :min_quantity,
                    min: 2,
                    placeholder: "5",
                    class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
                </div>

                <div>
                  <%= price_form.label :unit_price_cents, "Prix unitaire (€)", class: "block text-sm font-medium text-gray-700" %>
                  <%= price_form.text_field :unit_price_euros,
                    value: price_form.object.unit_price_cents.present? ? number_with_precision(price_form.object.unit_price_cents / 100.0, precision: 2) : nil,
                    name: "#{price_form.object_name}[unit_price_euros]",
                    placeholder: "2.40",
                    class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
                </div>

                <% if price_form.object.persisted? %>
                  <label class="mt-8 flex items-center gap-2 text-sm text-red-600">
                    <%= price_form.check_box :_destroy,
                      class: "rounded border-gray-300 text-red-600 focus:ring-red-600" %>
                    Supprimer
                  </label>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <%# Description wrapper %>
      <div class="md:col-span-2" data-controller="markdown-toolbar">
        <%= f.label :description, "Description", class: "block text-sm font-medium text-gray-700" %>

        <%# Markdown toolbar %>
        <div class="cursor-pointer mt-2 flex flex-wrap gap-2 rounded-t-xl border border-gray-300 border-b-0 bg-gray-50 p-2">

          <button
            type="button"
            data-action="click->markdown-toolbar#bold"
            class="cursor-pointer rounded-lg border border-gray-300 px-3 py-1 text-sm hover:bg-gray-100">
            B
          </button>

          <button
            type="button"
            data-action="click->markdown-toolbar#italic"
            class="cursor-pointer rounded-lg border border-gray-300 px-3 py-1 text-sm italic hover:bg-gray-100">
            I
          </button>

          <button
            type="button"
            data-action="click->markdown-toolbar#h2"
            class="cursor-pointer rounded-lg border border-gray-300 px-3 py-1 text-sm hover:bg-gray-100">
            H2
          </button>

          <button
            type="button"
            data-action="click->markdown-toolbar#list"
            class="cursor-pointer rounded-lg border border-gray-300 px-3 py-1 text-sm hover:bg-gray-100">
            • Liste
          </button>
        </div>

        <%= f.text_area :description,
          rows: 14,
          data: { markdown_toolbar_target: "textarea" },
          class: "block w-full rounded-b-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
      </div>

      <div>
        <%= f.label :price_euros, "Prix (€)", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :price_euros,
          value: number_with_precision(@product.price_cents.to_i / 100.0, precision: 2),
          class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
      </div>

      <div>
        <%= f.label :category_id, "Catégorie", class: "block text-sm font-medium text-gray-700" %>
        <%= f.collection_select :category_id,
          Category.order(:name),
          :id,
          :name,
          { prompt: "Choisir une catégorie" },
          class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
      </div>

      <div>
        <%= f.label :fulfillment_mode, "Disponibilité", class: "block text-sm font-medium text-gray-700" %>

        <%= f.select :fulfillment_mode,
          [
            ["Sur commande", "made_to_order"],
            ["Prêt à expédier", "ready_to_ship"]
          ],
          {},
          class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>

        <p class="mt-2 text-xs text-gray-500">
          “Sur commande” reste commandable sans stock. “Prêt à expédier” utilise le stock disponible.
        </p>
      </div>

      <div>
        <%= f.label :stock_quantity, "Stock disponible", class: "block text-sm font-medium text-gray-700" %>

        <%= f.number_field :stock_quantity,
          min: 0,
          class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>

        <p class="mt-2 text-xs text-gray-500">
          Utilisé uniquement pour les produits prêts à expédier.
        </p>
      </div>

      <div class="md:col-span-2">
        <%= f.label :images, "Images du produit", class: "block text-sm font-medium text-gray-700" %>
        <%= f.file_field :images, multiple: true, class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm file:mr-4 file:rounded-lg file:border-0 file:bg-gray-900 file:px-4 file:py-2 file:text-sm file:font-medium file:text-white hover:file:bg-gray-700" %>
      </div>

      <% if @product.persisted? && @product.images.attached? %>
        <div class="flex grid grid-cols-2 gap-4 sm:grid-cols-4">
          <% @product.images.each do |image| %>
            <% next unless image.blob&.persisted? %>

            <div class="relative rounded-xl border border-gray-200 bg-gray-50">
              <%= image_tag image, class: "rounded-xl h-32 w-full object-cover" %>

              <%= link_to "✕",
                remove_image_admin_product_path(@product, image_id: image.id),
                data: {
                  turbo_method: :delete,
                  turbo_confirm: "Supprimer cette image ?"
                },
                class: "z-100 absolute -top-2 -right-3 flex h-7 w-7 items-center justify-center rounded-full bg-red-600 text-white shadow hover:bg-red-700"
              %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="flex items-center gap-6 pt-2">
      <label class="flex items-center gap-2 text-sm text-gray-700">
        <%= f.check_box :published, class: "rounded border-gray-300" %>
        <span>Publié</span>
      </label>

      <label class="flex items-center gap-2 text-sm text-gray-700">
        <%= f.check_box :available, class: "rounded border-gray-300" %>
        <span>Disponible</span>
      </label>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "#{ action_name == 'new' ? 'Créer' : 'Mettre à jour' }", class: "rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>

      <%= link_to "Annuler",
        admin_products_path,
        class: "rounded-xl border border-gray-300 px-5 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    </div>
  <% end %>
</div>
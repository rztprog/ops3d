<nav class="bg-gray-900 text-white" data-controller="admin-navbar">
  <div class="mx-auto max-w-7xl px-4">
    
    <!-- TOP BAR -->
    <div class="flex h-16 items-center justify-between">
      
      <!-- Logo -->
      <%= link_to "OPS3D Admin",
        admin_root_path,
        class: "text-lg font-bold tracking-wide" %>

      <!-- Desktop menu -->
      <div class="hidden lg:flex items-center gap-5 text-sm">
        <%= link_to "Dashboard", admin_root_path, class: "text-gray-300 hover:text-white" %>
        <%= link_to "Produits", admin_products_path, class: "text-gray-300 hover:text-white" %>
        <%= link_to "Catégories", admin_categories_path, class: "text-gray-300 hover:text-white" %>
        <%= link_to "Commandes", admin_orders_path, class: "text-gray-300 hover:text-white" %>
        <%= link_to "Paramètres", edit_admin_settings_path, class: "text-gray-300 hover:text-white" %>
        <%= link_to "Utilisateurs", admin_users_path, class: "text-gray-300 hover:text-white" %>
        <%= link_to "Voir le site", root_path, class: "text-gray-300 hover:text-white" %>
      </div>

      <!-- Desktop auth -->
      <div class="hidden lg:flex items-center gap-4 text-sm">
        <span class="max-w-48 truncate text-gray-300">
          <%= current_user.email %>
        </span>

        <%= button_to "Déconnexion",
          destroy_user_session_path,
          method: :delete,
          class: "cursor-pointer rounded-lg bg-white/10 px-3 py-2 text-white hover:bg-white/20" %>
      </div>

      <!-- Burger mobile -->
      <button
        type="button"
        data-action="click->admin-navbar#toggle"
        class="inline-flex items-center justify-center rounded-lg p-2 text-gray-300 hover:bg-white/10 hover:text-white lg:hidden">
        <span class="sr-only">Ouvrir le menu</span>
        <i class="fa-solid fa-bars text-xl"></i>
      </button>
    </div>

    <!-- MOBILE MENU -->
    <div data-admin-navbar-target="menu" class="hidden border-t border-white/10 py-4 lg:hidden">
      <div class="flex flex-col gap-2 text-sm">

        <%= link_to "Dashboard", admin_root_path,
          data: { action: "click->admin-navbar#close" },
          class: "rounded-lg px-3 py-2 text-gray-300 hover:bg-white/10 hover:text-white" %>

        <%= link_to "Produits", admin_products_path,
          data: { action: "click->admin-navbar#close" },
          class: "rounded-lg px-3 py-2 text-gray-300 hover:bg-white/10 hover:text-white" %>

        <%= link_to "Catégories", admin_categories_path,
          data: { action: "click->admin-navbar#close" },
          class: "rounded-lg px-3 py-2 text-gray-300 hover:bg-white/10 hover:text-white" %>

        <%= link_to "Commandes", admin_orders_path,
          data: { action: "click->admin-navbar#close" },
          class: "rounded-lg px-3 py-2 text-gray-300 hover:bg-white/10 hover:text-white" %>

        <%= link_to "Paramètres", edit_admin_settings_path,
          data: { action: "click->admin-navbar#close" },
          class: "rounded-lg px-3 py-2 text-gray-300 hover:bg-white/10 hover:text-white" %>

        <%= link_to "Utilisateurs", admin_users_path,
          data: { action: "click->admin-navbar#close" },
          class: "rounded-lg px-3 py-2 text-gray-300 hover:bg-white/10 hover:text-white" %>

        <%= link_to "Voir le site", root_path,
          data: { action: "click->admin-navbar#close" },
          class: "rounded-lg px-3 py-2 text-gray-300 hover:bg-white/10 hover:text-white" %>

        <!-- USER -->
        <div class="mt-4 border-t border-white/10 pt-4">
          <p class="truncate px-3 text-xs text-gray-400">
            <%= current_user.email %>
          </p>

          <div class="mt-3 px-3">
            <%= button_to "Déconnexion",
              destroy_user_session_path,
              method: :delete,
              class: "w-full cursor-pointer rounded-lg bg-white/10 px-3 py-2 text-left text-sm text-white hover:bg-white/20" %>
          </div>
        </div>

      </div>
    </div>

  </div>
</nav>
<!-- HEADER -->
<div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">Utilisateurs</h1>
    <p class="mt-2 text-sm text-gray-500">
      Consulte les comptes clients et leurs commandes.
    </p>
  </div>

  <p class="text-sm font-medium text-gray-500">
    <%= pluralize(@customers.count, "client", plural: "clients") %>  
  </p>
</div>

<!-- DESKTOP TABLE -->
<div class="hidden overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm lg:block">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Utilisateur</th>
        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Rôle</th>
        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Commandes</th>
        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Date d'inscription</th>
      </tr>
    </thead>

    <tbody class="divide-y divide-gray-200 bg-white">
      <% @customers.each do |user| %>

        <% path = user.path %>
        <tr
          class="cursor-pointer hover:bg-gray-50"
          data-controller="row-link"
          data-row-link-url-value="<%= path %>"
          data-action="click->row-link#go"
        >
          <td class="px-6 py-4">
            <p class="font-medium text-gray-900">
              <%= [user.first_name, user.last_name].compact_blank.join(" ").presence || "Pas de nom renseigné" %>
            </p>
            <p class="text-sm text-gray-500"><%= user.email %></p>
          </td>

          <td class="px-6 py-4">
            <% if user.guest? %>
              <span class="rounded-full bg-orange-100 px-3 py-1 text-xs font-medium text-amber-800">
                Invité
              </span>
            <% elsif user.admin? %>
              <span class="rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-800">
                Admin
              </span>
            <% else %>
              <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700">
                Client
              </span>
            <% end %>
          </td>

          <td class="px-6 py-4 text-sm text-gray-700">
            <%= user.orders_count %>
          </td>

          <td class="px-6 py-4 text-sm text-gray-600">
            <%= l(user.created_at, format: :short) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<!-- MOBILE CARDS -->
<div class="space-y-4 lg:hidden">
  <% @customers.each do |user| %>
    <%= link_to user.guest? ? user.path : admin_user_path(user),
      class: "block rounded-2xl border border-gray-200 bg-white p-5 shadow-sm transition hover:bg-gray-50" do %>

      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="font-semibold text-gray-900">
            <%= [user.first_name, user.last_name].compact_blank.join(" ").presence || "Utilisateur" %>
          </p>

          <p class="mt-1 truncate text-sm text-gray-500">
            <%= user.email %>
          </p>
        </div>

        <% if user.admin? %>
          <span class="rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-800">
            Admin
          </span>
        <% else %>
          <span class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700">
            Client
          </span>
        <% end %>
      </div>

      <div class="mt-4 flex items-center justify-between gap-4">
        <div>
          <p class="text-xs uppercase tracking-wide text-gray-400">Commandes</p>
          <p class="mt-1 text-lg font-semibold text-gray-900">
            <%= user.orders_count %>
          </p>
        </div>

        <div class="text-right">
          <p class="text-xs uppercase tracking-wide text-gray-400">Inscrit le</p>
          <p class="mt-1 text-sm font-medium text-gray-700">
            <%= l(user.created_at, format: :short) %>
          </p>
        </div>
      </div>

    <% end %>
  <% end %>
</div>
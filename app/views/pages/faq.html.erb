<div class="mx-auto container px-4 py-12">
  <div class="mb-10">
    <p class="text-sm font-semibold uppercase tracking-wide text-[color:var(--light)]">OPS3D</p>
    <h1 class="mt-2 text-3xl font-black uppercase tracking-wide text-gray-900">FAQ</h1>
    <p class="mt-3 text-sm text-gray-500">Questions fréquentes sur les produits, la commande et la livraison.</p>
  </div>

  <div class="space-y-4">
    <% [
      ["Vendez-vous des fichiers STL ?", "Non. OPS3D vend uniquement des pièces physiques imprimées en 3D."],
      ["Les pièces sont-elles fabriquées à la demande ?", "Oui, une partie des produits peut être fabriquée à la demande selon les commandes."],
      ["Quels sont les délais de préparation ?", "Les délais dépendent du produit, de la charge de fabrication et de la livraison. Une estimation plus précise pourra être communiquée après commande."],
      ["Puis-je demander une pièce personnalisée ?", "Oui, selon le besoin. La demande pourra être étudiée au cas par cas via la page contact."],
      ["Quels moyens de paiement sont acceptés ?", "Le paiement en ligne est sécurisé via Stripe."],
      ["Puis-je annuler ma commande ?", "Cela dépend de l'état de préparation de la commande. Contacte OPS3D le plus rapidement possible après la commande."],
      ["Puis-je retourner un produit ?", "Le droit de rétractation s'applique selon les règles légales, sauf exceptions, notamment pour les produits personnalisés."]
    ].each do |question, answer| %>
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-gray-900"><%= question %></h2>
        <p class="mt-3 text-sm leading-7 text-gray-600"><%= answer %></p>
      </div>
    <% end %>
  </div>
</div>
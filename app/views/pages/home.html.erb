  <!-- FEATURED PRODUCTS -->
  <section class="mx-auto container px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-10">
      <div class="flex items-center gap-4">
        <div class="mb-12 text-center">
          <h2 class="text-3xl font-black uppercase leading-tight tracking-wide text-[color:var(--dark)] sm:text-4xl">
            <%= t(".section.featured.title") %>
          </h2>

          <div class="mt-6">
            <%= link_to t(".section.featured.cta"),
              products_path,
              class: "inline-flex w-full items-center justify-center rounded-xl bg-[color:var(--dark)] px-8 py-4 text-sm font-semibold uppercase text-white transition hover:bg-[color:var(--light)] sm:w-auto" %>
          </div>
        </div>
      </div>
    </div>

    <% if @featured_products.any? %>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <% @featured_products.each do |product| %>
          <div class="cursor-pointer group overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
            <%= link_to product_path(product), class: "block" do %>
              <div class="aspect-square overflow-hidden bg-gray-100">
                <% if product.images.attached? %>
                  <%= image_tag product.images.first, class: "h-full w-full object-cover transition duration-300 group-hover:scale-105" %>
                <% else %>
                  <div class="flex h-full w-full items-center justify-center text-sm text-gray-400">
                    Pas d'image
                  </div>
                <% end %>
              </div>
            <% end %>

            <div class="p-4">
              <% if product.category.present? %>
                <p class="text-xs font-medium uppercase tracking-wide text-gray-400">
                  <%= product.category.name %>
                </p>
              <% end %>

              <h3 class="mt-2 text-lg font-semibold text-gray-900">
                <%= link_to product.name, product_path(product), class: "hover:underline" %>
              </h3>

              <p class="mt-2 text-sm text-gray-500">
                <%= truncate(product.description.to_s, length: 80) %>
              </p>

              <div class="mt-4 flex items-center justify-between gap-4">
                <p class="text-lg font-bold text-gray-900">
                  <%= number_to_currency(product.price_cents / 100.0, unit: "€") %>
                </p>

                <%= button_to t(".section.featured.add"),
                  cart_items_path(product_id: product.id),
                  method: :post,
                  class: "rounded-xl bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700 cursor-pointer" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
        <h3 class="text-lg font-semibold text-gray-900"><%= t(".section.featured.comming") %></h3>
        <p class="mt-2 text-gray-500"><%= t(".section.featured.subcomming") %></p>
      </div>
    <% end %>
  </section>

  <!-- CTA FINAL -->
  <section class="border-t border-gray-200 bg-gray-200">
    <div class="mx-auto max-w-4xl px-4 py-20 text-center sm:px-6 lg:px-8">

      <h2 class="text-3xl font-black uppercase leading-tight tracking-wide text-[color:var(--dark)] sm:text-4xl">
        <%= t(".section.finalcta.title") %>
      </h2>

      <p class="mx-auto mt-6 max-w-2xl text-base leading-7 text-gray-600 sm:text-lg">
        <%= t(".section.finalcta.subtitle") %>
      </p>

      <div class="mt-10">
        <%= link_to t('.section.finalcta.cta'),
          products_path,
          class: "inline-flex w-full items-center justify-center rounded-xl bg-[color:var(--dark)] px-8 py-4 text-sm font-semibold uppercase tracking-wide text-white transition hover:bg-[color:var(--light)] sm:w-auto" %>
      </div>

    </div>
  </section>
</div>
<div class="bg-gray-100">
  <!-- HERO -->
  <section class="mx-auto container px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-[color:var(--light)] sm:text-sm">
          <%= t(".hero.first") %>
        </p>

        <h1 class="mt-5 text-5xl font-black uppercase leading-none tracking-tight text-[color:var(--dark)] sm:text-6xl lg:text-7xl">
          OPS3D
          <span class="mt-2 block text-xl leading-snug text-[color:var(--light)] sm:text-2xl lg:text-3xl">
            <%= t(".hero.title") %>
          </span>
        </h1>

        <p class="mt-6 max-w-xl text-base leading-8 text-gray-700 sm:text-lg">
          <%= t(".hero.subtitle") %>
        </p>

        <div class="mt-8">
          <%= link_to t(".hero.cta"),
            products_path,
            class: "inline-flex w-full items-center justify-center rounded-xl bg-[color:var(--dark)] px-8 py-4 text-sm font-semibold uppercase text-white transition hover:bg-[color:var(--light)] sm:w-auto" %>
        </div>
      </div>

      <div class="relative hidden lg:block">
        <div class="overflow-hidden rounded-3xl border border-gray-200 bg-gray-100 shadow-sm">
          <%= cl_image_tag(
            "ultis5v1",
            class: "aspect-[4/3] w-full object-cover object-[center_70%]",
            crop: :fill,
            quality: "auto",
            fetch_format: "auto"
          ) %>
        </div>
      </div>
    </div>
  </section>


<div class="mx-auto px-4 py-10">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900"><%= t(".title") %></h1>
    <p class="mt-2 text-sm text-gray-500">
      <%= pluralize(@cart_items.sum(&:quantity), "article", plural: 'articles') %> <%= t(".inCart") %>
    </p>
  </div>

  <% if @cart_items.empty? %>
    <!-- Si le panier est vide -->
    <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
      <h2 class="text-xl font-semibold text-gray-900"><%= t(".empty") %></h2>
      <p class="mt-2 text-gray-500"><%= t(".addSomething") %></p>

      <div class="mt-6">
        <%= link_to t(".all"),
          products_path,
          class: "inline-flex items-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>
      </div>
    </div>
  <% else %>
    <hr class="mb-8 text-gray-300"/>
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
      <!-- Colonne gauche -->
      <div class="lg:col-span-2 space-y-4">
        <% @cart_items.each do |item| %>
          <% product = item.product %>
          <% line_total_cents = item.quantity * product.price_cents %>

          <div class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex flex-col gap-4 sm:flex-row">
              <div class="h-28 w-28 shrink-0 overflow-hidden rounded-xl bg-gray-100">
                <% if product.images.attached? %>
                  <%= image_tag product.images.first, class: "h-full w-full object-cover" %>
                <% else %>
                  <div class="flex h-full w-full items-center justify-center text-xs text-gray-400">
                    <%= t(".image")%>
                  </div>
                <% end %>
              </div>

              <!-- Informations complémentaires (Custom fields) -->
              <div class="flex flex-1 flex-col justify-between gap-4">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h2 class="text-lg font-semibold text-gray-900">
                      <%= link_to product.name, product_path(product), class: "hover:underline" %>
                    </h2>

                    <% if item.cart_item_custom_field_values.any? %>
                      <div class="mt-3 rounded-xl bg-gray-50 p-3">
                        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 underline">
                          Informations complémentaires
                        </p>

                        <dl class="mt-2 space-y-1 text-sm">
                          <% item.cart_item_custom_field_values.includes(:product_custom_field).each do |custom_value| %>
                            <div class="flex justify-between gap-4">
                              <dt class="text-gray-500">
                                <%= custom_value.product_custom_field.label %>
                              </dt>

                              <dd class="text-right font-medium text-gray-900">
                                <%= custom_value.value.presence || "—" %>
                              </dd>
                            </div>
                          <% end %>
                        </dl>
                      </div>
                    <% end %>

                    <% if product.description.present? %>
                      <p class="mt-1 text-sm text-gray-500">
                        <%= truncate(product.description, length: 110) %>
                      </p>
                    <% end %>

                    <p class="mt-3 text-sm text-gray-700">
                      <%= t(".unit")%> :
                      <span class="font-medium">
                        <%= number_to_currency(product.price_cents / 100.0, unit: "€") %>
                      </span>
                    </p>
                  </div>

                  <div class="text-right">
                    <p class="text-sm text-gray-500"><%= t(".total")%></p>
                    <p class="text-lg font-semibold text-gray-900">
                      <%= number_to_currency(line_total_cents / 100.0, unit: "€") %>
                    </p>
                  </div>
                </div>

                <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                  <%= form_with model: item, url: cart_item_path(item), method: :patch, local: true, class: "flex items-end gap-3" do |f| %>
                    <div>
                      <%= f.label :quantity, t(".quantity"), class: "block text-sm font-medium text-gray-700" %>
                      <%= f.number_field :quantity,
                        min: 1,
                        class: "mt-1 w-24 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-gray-900 focus:outline-none" %>
                    </div>

                    <%= f.submit t(".update"),
                      class: "cursor-pointer rounded-xl border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:text-white hover:bg-[color:var(--dark)]" %>
                  <% end %>

                  <%= button_to t(".delete"),
                    cart_item_path(item),
                    method: :delete,
                    class: "rounded-xl px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-50" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <div class="pt-2">
          <%= link_to t(".continue"),
            products_path,
            class: "text-sm font-medium text-gray-700 hover:text-gray-900 hover:underline" %>
        </div>
      </div>

      <!-- Colonne droite -->
      <div class="lg:col-span-1">
        <div class="sticky top-6 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-gray-900"><%= t(".sum")%></h2>

          <div class="mt-6 space-y-4 text-sm">
            <div class="flex items-center justify-between text-gray-600">
              <span><%= t(".ship") %></span>
              <span><%= number_to_currency(@subtotal_cents / 100.0, unit: "€") %></span>
            </div>

            <div class="flex items-center justify-between text-gray-600">
              <span><%= t(".fee") %></span>
              <span><%= number_to_currency(@shipping_cents / 100.0, unit: "€") %></span>
            </div>

            <div class="border-t border-gray-200 pt-4">
              <div class="flex items-center justify-between text-base font-semibold text-gray-900">
                <span><%= t(".total") %></span>
                <span><%= number_to_currency(@total_cents / 100.0, unit: "€") %></span>
              </div>
            </div>
          </div>

          <div class="mt-6">
            <% if user_signed_in? %>
              <%= link_to t(".order"),
                new_order_path,
                class: "inline-flex w-full items-center justify-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>
            <% else %>
              <%= link_to t(".connect"),
                new_user_session_path,
                class: "inline-flex w-full items-center justify-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>
            <% end %>
          </div>

          <p class="mt-4 text-xs leading-5 text-gray-500">
            <%= t(".lastp")%>
          </p>
        </div>
      </div>
    </div>
  <% end %>
</div>
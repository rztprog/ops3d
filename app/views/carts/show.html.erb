<div class="mx-auto py-10">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900"><%= t(".title") %></h1>
    <p class="mt-2 text-sm text-gray-500">
      <%= pluralize(@cart_items.sum(&:quantity), "article", plural: 'articles') %> <%= t(".inCart") %>
    </p>
  </div>

  <% if @cart_items.empty? %>
    <!-- Si le panier est vide -->
    <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
      <h2 class="text-xl font-semibold text-gray-900"><%= t(".empty") %></h2>
      <p class="mt-2 text-gray-500"><%= t(".addSomething") %></p>

      <div class="mt-6">
        <%= link_to t(".all"),
          products_path,
          class: "inline-flex items-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>
      </div>
    </div>
  <% else %>
    <div class="mb-6 rounded-2xl border border-gray-200 bg-gray-50 p-4">
      <% if @free_shipping_unlocked %>
        <p class="text-sm font-medium text-green-700">
          Livraison offerte débloquée.
        </p>
      <% else %>
        <p class="text-sm font-medium text-gray-900">
          Plus que
          <%= number_to_currency(@amount_until_free_shipping_cents / 100.0, unit: "€") %>
          pour profiter de la livraison offerte.
        </p>
      <% end %>

      <div class="mt-3 h-2 overflow-hidden rounded-full bg-gray-200">
        <div
          class="h-full rounded-full transition-all duration-500 ease-out <%= @free_shipping_unlocked ? 'bg-green-500' : 'bg-[color:var(--dark)]' %>"
          style="width: <%= @free_shipping_progress_percent %>%">
        </div>
      </div>

      <p class="mt-2 text-xs text-gray-500">
        Livraison offerte dès
        <%= number_to_currency(@free_shipping_threshold_cents / 100.0, unit: "€") %>
        d'achat.
      </p>
    </div>
    <hr class="mb-8 text-gray-300"/>
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
      <!-- Colonne gauche -->
      <div class="lg:col-span-2 space-y-4">
        <% @cart_items.each do |item| %>
          <% product = item.product %>
          <% unit_price_cents = product.unit_price_cents_for(item.quantity) %>
          <% line_total_cents = item.quantity * unit_price_cents %>

          <div class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex flex-col gap-4 sm:flex-row">
              <div class="h-28 w-28 shrink-0 overflow-hidden rounded-xl bg-gray-100">
                <% if product.images.attached? %>
                  <%= image_tag product.images.first, class: "h-full w-full object-cover" %>
                <% else %>
                  <div class="flex h-full w-full items-center justify-center text-xs text-gray-400">
                    <%= t(".image")%>
                  </div>
                <% end %>
              </div>

              <div class="flex flex-1 flex-col justify-between gap-4">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h2 class="text-lg font-semibold text-gray-900">
                      <%= link_to product.name, product_path(product), class: "hover:underline" %>
                    </h2>

                    <% if product.description.present? %>
                      <p class="mt-1 text-sm text-gray-500">
                        <%= truncate(
                          product.description.to_s
                            .gsub(/[#*_`>\-\[\]\(\)]/, ""),
                          length: 90
                        ) %>
                      </p>
                    <% end %>

                    <!-- Informations complémentaires (Custom fields) -->
                    <% if item.cart_item_custom_field_values.any? %>
                      <div class="mt-3 rounded-xl bg-gray-50 p-3">
                        <p class="text-xs font-semibold uppercase tracking-wide text-gray-500 underline">
                          Informations complémentaires
                        </p>

                        <dl class="mt-2 space-y-1 text-sm">
                          <% item.cart_item_custom_field_values.includes(:product_custom_field).each do |custom_value| %>
                            <div class="flex justify-between gap-4">
                              <dt class="text-gray-500">
                                <%= custom_value.product_custom_field.label %>
                              </dt>

                              <dd class="text-right font-medium text-gray-900">
                                <%= custom_value.value.presence || "—" %>
                              </dd>
                            </div>
                          <% end %>
                        </dl>
                      </div>
                    <% end %>

                    <p class="mt-3 text-sm text-gray-700">
                      <%= t(".unit")%> :
                      <span class="font-medium">
                        <% if unit_price_cents < product.price_cents %>
                          <span class="line-through text-gray-400">
                            <%= number_to_currency(product.price_cents / 100.0, unit: "€") %>
                          </span>

                          <span class="font-semibold text-green-700">
                            <%= number_to_currency(unit_price_cents / 100.0, unit: "€") %>
                          </span>
                        <% else %>
                          <span class="font-medium">
                            <%= number_to_currency(unit_price_cents / 100.0, unit: "€") %>
                          </span>
                        <% end %>                      
                      </span>
                    </p>
                  </div>

                  <div class="text-right">
                    <p class="text-sm text-gray-500"><%= t(".total")%></p>
                    <p class="text-lg font-semibold text-gray-900">
                      <%= number_to_currency(line_total_cents / 100.0, unit: "€") %>
                    </p>
                  </div>
                </div>

                <div class="flex flex-col items-start gap-3 sm:flex-row sm:items-end sm:justify-between">
                  <div class="inline-flex items-center rounded-full border-2 border-yellow-400 bg-white px-2 cursor-pointer">
                    <% if item.quantity > 1 %>
                      <%= button_to cart_item_path(item, cart_item: { quantity: item.quantity - 1 }),
                        method: :patch,
                        class: "flex h-8 w-8 items-center justify-center px-2 cursor-pointer text-black hover:text-[color:var(--light)]" do %>
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 512 512"
                          class="fill-current"
                        >
                          <g transform="translate(0.000000,512.000000) scale(0.100000,-0.100000)">
                            <path d="M0 2560 l0 -160 2560 0 2560 0 0 160 0 160 -2560 0 -2560 0 0 -160z"/>
                          </g>
                        </svg>
                      <% end %>
                    <% else %>
                      <%= button_to cart_item_path(item),
                        method: :delete,
                        class: "flex h-8 w-8 items-center px-2 justify-center text-gray-900 cursor-pointer text-black hover:text-[color:var(--light)]" do %>
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 512 512"
                          class="fill-current"
                        >
                          <g transform="translate(0.000000,512.000000) scale(0.100000,-0.100000)">
                            <path d="M1885 5101 c-77 -34 -112 -100 -103 -190 l3 -40 -546 -3 -545 -3 -37
                            -25 c-43 -29 -87 -108 -87 -154 1 -69 65 -156 128 -174 35 -9 3689 -9 3724 0
                            63 18 127 105 128 174 0 46 -44 125 -87 154 l-37 25 -545 3 -546 2 3 40 c9 91
                            -26 157 -103 191 -37 17 -80 19 -675 19 -595 0 -638 -2 -675 -19z"/>
                            <path d="M680 4169 c-32 -13 -78 -56 -96 -91 -8 -15 -14 -51 -14 -81 0 -70
                            415 -3799 429 -3855 15 -58 46 -98 96 -122 41 -20 62 -20 1465 -20 1403 0
                            1424 0 1465 20 50 24 81 64 96 122 14 56 429 3785 429 3855 0 30 -6 66 -14 81
                            -19 36 -65 78 -99 91 -38 15 -3721 14 -3757 0z m3483 -356 c3 -6 -376 -3416
                            -382 -3440 -1 -2 -550 -3 -1221 -3 -671 0 -1220 1 -1221 3 -6 24 -385 3434
                            -382 3440 5 9 3201 9 3206 0z"/>
                            <path d="M2524 3400 c-54 -12 -101 -48 -123 -94 -21 -42 -21 -49 -21 -1214 0
                            -1276 -3 -1208 56 -1264 36 -33 74 -48 124 -48 50 0 88 15 124 48 59 56 56
                            -12 56 1264 0 1169 0 1172 -21 1215 -33 68 -121 110 -195 93z"/>
                            <path d="M1643 3099 c-44 -13 -100 -70 -114 -118 -10 -33 1 -172 71 -902 47
                            -498 87 -877 95 -894 29 -68 94 -109 172 -109 42 0 60 5 94 29 57 41 79 85 79
                            160 0 33 -36 432 -79 886 -56 592 -83 834 -94 855 -42 82 -133 119 -224 93z"/>
                            <path d="M3350 3095 c-43 -20 -77 -51 -97 -89 -11 -21 -38 -265 -94 -855 -43
                            -454 -79 -853 -79 -886 0 -75 22 -119 79 -160 33 -23 52 -29 94 -29 101 0 170
                            63 187 170 4 32 43 430 86 885 l78 825 -23 48 c-42 85 -149 127 -231 91z"/>
                          </g>
                        </svg>
                      <% end %>
                    <% end %>

                    <span class="min-w-8 px-2 text-lg font-semibold text-center">
                      <%= item.quantity %>
                    </span>

                    <%= button_to cart_item_path(item, cart_item: { quantity: item.quantity + 1 }),
                      method: :patch,
                      class: "flex h-10 w-10 items-center justify-center text-2xl font-bold px-3 cursor-pointer text-black hover:text-[color:var(--light)]" do %>
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 512 512"
                          class="fill-current"
                        >
                          <g transform="translate(0.000000,512.000000) scale(0.100000,-0.100000)">
                            <path d="M2400 3920 l0 -1200 -1200 0 -1200 0 0 -160 0 -160 1200 0 1200 0 0
                            -1200 0 -1200 160 0 160 0 0 1200 0 1200 1200 0 1200 0 0 160 0 160 -1200 0
                            -1200 0 0 1200 0 1200 -160 0 -160 0 0 -1200z"/>
                          </g>
                        </svg>
                      <% end %>
                  </div>

                  <%= button_to t(".delete"),
                    cart_item_path(item),
                    method: :delete,
                    class: "cursor-pointer rounded-xl px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-50" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <div class="pt-2">
          <%= link_to t(".continue"),
            products_path,
            class: "text-sm font-medium text-gray-700 hover:text-gray-900 hover:underline" %>
        </div>
      </div>

      <!-- Colonne droite -->
      <div class="lg:col-span-1">
        <div class="sticky top-6 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-gray-900"><%= t(".sum")%></h2>

          <div class="mt-6 space-y-4 text-sm">
            <div class="flex items-center justify-between text-gray-600">
              <span><%= t(".ship") %></span>
              <span><%= number_to_currency(@subtotal_cents / 100.0, unit: "€") %></span>
            </div>

            <div class="flex items-center justify-between text-gray-600">
              <span><%= t(".fee") %></span>
              <span><%= number_to_currency(@shipping_cents / 100.0, unit: "€") %></span>
            </div>

            <div class="border-t border-gray-200 pt-4">
              <% if @applied_promo.present? %>
                <div class="mt-3 rounded-xl bg-green-50 px-4 py-3 text-sm border border-green-200">
                  <div class="flex items-center justify-between gap-4">
                    <div>
                      <p class="font-semibold text-green-800">
                        <%= @applied_promo.code %>
                      </p>

                      <p class="text-green-700">
                        <%= number_to_currency(@discount_cents / 100.0, unit: "€") %>
                      </p>
                    </div>

                    <%= button_to "✕",
                      remove_promo_code_cart_path,
                      method: :delete,
                      class: "cursor-pointer flex h-7 w-7 items-center justify-center rounded-full bg-red-600 text-white shadow hover:bg-red-700",
                      form: {
                        class: "inline-block"
                      }
                    %>
                  </div>
                </div>
              <% else %>
                <% promo_error = flash[:promo_code_error].present? %>

                <%= form_with url: apply_promo_code_cart_path,
                  method: :post,
                  local: true,
                  class: "flex gap-2" do %>

                  <%= text_field_tag :code,
                    nil,
                    placeholder: t('.code'),
                    class: "block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none #{promo_error ? 'animate-promo-error' : ''}" %>

                  <%= submit_tag t('.apply'),
                    class: "cursor-pointer rounded-xl bg-gray-900 px-4 py-3 text-sm font-medium text-white hover:bg-gray-700" %>
                <% end %>
              <% end %>
            </div>

            <% if @discount_cents.to_i > 0 %>
              <div class="flex items-center justify-between text-green-700">
                <span><%= t('.discount') %></span>
                <span>
                  -<%= number_to_currency(@discount_cents / 100.0, unit: "€") %>
                </span>
              </div>
            <% end %>

            <div class="border-t border-gray-200 pt-4">
              <div class="flex items-center justify-between text-base font-semibold text-gray-900">
                <span><%= t(".total") %></span>
                <span class="text-xl"><%= number_to_currency(@total_cents / 100.0, unit: "€") %></span>
              </div>
            </div>
          </div>

          <div class="mt-6">
            <%= link_to t(".order"),
              new_order_path,
              class: "inline-flex w-full items-center justify-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>
          </div>

          <p class="mt-4 text-xs leading-5 text-gray-500">
            <%= t(".lastp")%>
          </p>
        </div>
      </div>
    </div>
  <% end %>
</div>
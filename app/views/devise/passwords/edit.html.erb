<div class="mx-auto max-w-md py-12">
  <div class="mb-8 text-center">
    <h1 class="text-3xl font-bold text-gray-900">
      <%= t("devise.passwords.edit.title", default: "Change ton mot de passe") %>
    </h1>

    <p class="mt-2 text-sm text-gray-500">
      <%= t("devise.passwords.edit.subtitle", default: "Entre ton nouveau mot de passe.") %>
    </p>
  </div>

  <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }, class: "space-y-6") do |f| %>
      <% if resource.errors.any? %>
        <div class="mb-6 rounded-xl border border-red-200 bg-red-50 p-4">
          <h2 class="text-sm font-semibold text-red-800">
            Le formulaire contient <%= pluralize(resource.errors.count, "erreurs") %>.
          </h2>

          <ul class="mt-2 list-disc pl-5 text-sm text-red-700">
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <%= f.hidden_field :reset_password_token %>

      <div class="field">
        <p><%= f.label :password, t('devise.passwords.edit.new'), class: "block text-sm font-medium text-gray-700" %></p>
        <% if @minimum_password_length %>
          <p><em>(<%= @minimum_password_length %> <%= t('devise.passwords.edit.mini') %>)</em></p>
        <% end %>
        <p><%= f.password_field :password, 
              autofocus: true, 
              autocomplete: t('devise.passwords.edit.newp'),
              class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %></p>
      </div>

      <div class="mt-6 field">
        <p><%= f.label :password_confirmation, t('devise.passwords.edit.confirm') %></p>
        <p><%= f.password_field :password_confirmation, 
              autocomplete: t('devise.passwords.edit.newp'),
              class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %></p>
      </div>

      <div class="mt-6 actions">
        <%= f.submit t('devise.passwords.edit.change'), 
            class: "w-full cursor-pointer rounded-xl bg-gray-900 px-6 py-3 text-sm font-medium text-white transition hover:bg-gray-700" %>
      </div>
    <% end %>

    <div class="mt-6 border-t border-gray-200 pt-6 text-center text-sm">
      <%= link_to t("devise.shared.links.sign_in", default: t('devise.passwords.new.back')),
        new_session_path(resource_name),
        class: "font-medium text-[color:var(--light)] hover:underline" %>
    </div>
  </div>
</div>
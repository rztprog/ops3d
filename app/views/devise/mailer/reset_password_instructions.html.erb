<div style="margin:0;padding:40px 20px;background:#f5f5f5;font-family:Arial,sans-serif;color:#111827;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0">
    <tr>
      <td align="center">
        <table
          role="presentation"
          width="100%"
          cellspacing="0"
          cellpadding="0"
          style="max-width:640px;background:#ffffff;border-radius:24px;overflow:hidden;border:1px solid #e5e7eb;"
        >
          <!-- Header -->
          <tr>
            <td style="padding:32px 40px;background: #1F3046;color:#ffffff;">
              <h1 style="margin:0;font-size:28px;font-weight:700;">
                OPS3D
              </h1>

              <h2 style="margin:12px 0 0;font-size:15px;line-height:1.6;color:#d1d5db;">
                <%= t("devise.reset.title") %>
              </h2>
              
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding:40px;">
              <p style="margin:0 0 24px;font-size:16px;line-height:1.7;">
                <%= t("devise.confirm.hello") %> <strong><%= @resource.email %></strong>.
              </p>

              <p style="margin:0 0 16px;font-size:16px;line-height:1.7;color:#374151;">
                <%= t('devise.reset.description') %>
              </p>
 
              <p style="margin:0 0 16px;font-size:16px;line-height:1.7;color:#374151;">
                <%= t('devise.reset.ignore') %>
              </p>

              <p style="margin:0 0 16px;font-size:16px;line-height:1.7;color:#374151;">
                <%= t('devise.reset.new') %>
              </p>

              <!-- Button -->
              <div style="margin-top:32px;text-align:center;">
                <%= link_to t('devise.reset.button'),
                  edit_password_url(@resource, reset_password_token: @token),
                  style: "
                    display:inline-block;
                    padding:26px 36px;
                    background:#1F3046;
                    color:#ffffff;
                    text-decoration:none;
                    border-radius:14px;
                    font-size:20px;
                    font-weight:600;
                    cursor: pointer;
                  " %>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td
              style="padding:24px 40px;border-top:1px solid #e5e7eb;font-size:13px;color:#9ca3af;text-align:center;"
            >
              © OPS3D 2026 — L'exigence terrain appliquée à l'impression 3D
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</div>
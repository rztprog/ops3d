<% content_for :title, "#{@product.name} - Impression 3D personnalisée | OPS3D" %>
<% content_for :description,
  truncate(@product.description.to_s, length: 150) %>
<% content_for :og_image do %>
  <%= cl_image_path(@product.images.first.key) if @product.images.attached? %>
<% end %>
<div class="px-4 py-10">
  <div class="mb-6">
    <%= link_to t(".back"), products_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 hover:underline" %>
  </div>

  <div class="grid grid-cols-1 gap-10 lg:grid-cols-2">
    <!-- Galerie -->
    <div>
      <div class="overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm">
        <% if @product.images.attached? %>
          <%= image_tag @product.images.first, class: "h-full w-full object-cover" %>
        <% else %>
          <div class="flex aspect-square items-center justify-center bg-gray-100 text-sm text-gray-400">
            <%= t(".image") %>
          </div>
        <% end %>
      </div>

      <% if @product.images.attached? && @product.images.size > 1 %>
        <div class="mt-4 grid grid-cols-4 gap-3">
          <% @product.images.each do |image| %>
            <div class="overflow-hidden rounded-xl border border-gray-200 bg-white">
              <%= image_tag image, class: "aspect-square h-full w-full object-cover" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Infos produit -->
    <div class="lg:sticky lg:top-6 h-fit">
      <% if @product.category.present? %>
        <p class="text-sm font-medium uppercase tracking-wide text-gray-400">
          <%= @product.category.name %>
        </p>
      <% end %>

      <h1 class="mt-2 text-3xl font-bold text-gray-900">
        <%= @product.name %>
      </h1>

      <p class="mt-4 text-3xl font-bold text-gray-900">
        <%= number_to_currency(@product.price_cents / 100.0, unit: "€") %>
      </p>

      <div class="mt-6 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500">
          <%= t(".description")%>
        </h2>

        <div class="mt-3 prose prose-sm max-w-none text-gray-600">
          <p><%= simple_format(@product.description) %></p>
        </div>
      </div>

      <div class="mt-6 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-500"><%= t(".available") %></span>
          <span class="rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-700">
            <%= t(".stock")%>
          </span>
        </div>

        <% if user_signed_in? %>
          <%= form_with url: cart_items_path, method: :post, local: true, class: "mt-8 space-y-6" do |f| %>
            <%= hidden_field_tag :product_id, @product.id %>

            <% if @custom_fields.any? %>
              <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                <h2 class="text-lg font-semibold text-gray-900">
                  <%= t('.info')%>
                </h2>

                <p class="mt-1 text-sm text-gray-500">
                  <%= t('.info_desc')%>
                </p>

                <div class="mt-6 space-y-4">
                  <% @custom_fields.each do |custom_field| %>
                    <div>
                      <label class="block text-sm font-medium text-gray-700">
                        <%= custom_field.label %>
                        <% if custom_field.required? %>
                          <span class="text-red-500">*</span>
                        <% end %>
                      </label>

                      <% field_name = "custom_fields[#{custom_field.id}]" %>

                      <% case custom_field.field_type %>
                      <% when "textarea" %>
                        <%= text_area_tag field_name,
                          nil,
                          placeholder: custom_field.placeholder,
                          required: custom_field.required?,
                          rows: 4,
                          class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>

                      <% when "number" %>
                        <%= number_field_tag field_name,
                          nil,
                          placeholder: custom_field.placeholder,
                          required: custom_field.required?,
                          class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>

                      <% when "checkbox" %>
                        <label class="mt-2 flex items-center gap-2 text-sm text-gray-700">
                          <%= check_box_tag field_name, "1", false, class: "rounded border-gray-300 text-gray-900 focus:ring-gray-900" %>
                          <%= t('.yes')%>
                        </label>

                      <% else %>
                        <%= text_field_tag field_name,
                          nil,
                          placeholder: custom_field.placeholder,
                          required: custom_field.required?,
                          class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <%= submit_tag t('.add'),
              class: "w-full rounded-xl bg-gray-900 px-6 py-4 text-sm font-semibold uppercase text-white hover:bg-gray-700 cursor-pointer" %>
          <% end %>
        <% else %>
          <div class="mt-6">          
            <% if @custom_fields.any? %>
              <%= link_to t('.login'),
                new_user_session_path(return_to: product_path(@product)),
                class: "cursor-pointer inline-flex w-full items-center justify-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>
            <% else %>
              <%= button_to cart_items_path(product_id: @product),
                method: :post,
                form_class: "hidden sm:block",
                class: "cursor-pointer inline-flex w-full items-center justify-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" do %>
                <%= t('.add') %>
              <% end %>
            <% end %>
          </div>
        <% end %>
        <p class="mt-4 text-xs leading-5 text-gray-500">
          <%= t(".subtitle")%>
        </p>
      </div>
    </div>
  </div>
</div>
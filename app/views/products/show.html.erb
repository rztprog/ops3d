<h1 class="text-2xl font-bold"><%= @product.name %></h1>

<p class="mt-4">
  <%= @product.description %>
</p>

<p class="mt-4 text-xl font-semibold">
  <%= number_to_currency(@product.price_cents / 100.0, unit: "€") %>
</p>

<%= button_to "Ajouter au panier",
              cart_items_path(product_id: @product.id),
              method: :post,
              class: "mt-6 bg-blue-500 text-white px-4 py-2 rounded" %>
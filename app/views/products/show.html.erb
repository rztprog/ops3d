<% content_for :title, "#{@product.name} - Impression 3D | OPS3D" %>
<% content_for :description,
  truncate(@product.description.to_s.gsub(/[#*_`>\-\[\]\(\)]/, ""), length: 125) %>
<% content_for :og_image do %>
  <%= cl_image_path(@product.images.first.key, width: 1200, height: 630, crop: :fill, quality: "auto:eco", fetch_format: "jpg") if @product.images.attached? %>
<% end %>

<div class="py-10">
  <nav class="mb-6 text-sm text-gray-500">
    <% breadcrumbs_for(@product).each_with_index do |item, index| %>

      <% unless index.zero? %>
        <span class="mx-2"> > </span>
      <% end %>

      <% if index == breadcrumbs_for(@product).size - 1 %>
        <span class="font-medium text-gray-900">
          <%= item[:name] %>
        </span>
      <% else %>
        <%= link_to item[:name],
          item[:url],
          class: "hover:text-gray-900 hover:underline" %>
      <% end %>

    <% end %>
  </nav>
  <div class="mb-6">
    <%= link_to t(".back"), products_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 hover:underline" %>
  </div>

  <div class="grid grid-cols-1 gap-10 lg:grid-cols-2">
    <!-- Galerie -->
    <div data-controller="gallery">
      <div class="overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm">
        <% if @product.images.attached? %>
          <%= cl_image_tag @product.images.first.key,
            width: 1200,
            height: 1200,
            crop: :fill,
            gravity: :auto,
            quality: :auto,
            fetch_format: :auto,
            loading: "eager",
            decoding: "async",
            class: "h-full w-full object-cover",
            alt: @product.name,
            data: { gallery_target: "main" } %>
        <% else %>
          <div class="flex aspect-square items-center justify-center bg-gray-100 text-sm text-gray-400">
            <%= t(".image") %>
          </div>
        <% end %>
      </div>

      <% if @product.images.attached? && @product.images.size > 1 %>
        <div class="mt-4 grid grid-cols-4 gap-3">
          <% @product.images.each do |image| %>
            <button
              type="button"
              data-action="click->gallery#change"
              data-image="<%= cl_image_path(
                image.key,
                width: 300,
                height: 300,
                crop: :fill,
                gravity: :auto,
                quality: :auto,
                fetch_format: :webp
              ) %>"
              class="overflow-hidden rounded-xl border border-gray-200 bg-white cursor-pointer"
            >
              <%= cl_image_tag image.key,
                width: 300,
                height: 300,
                crop: :fill,
                gravity: :auto,
                quality: :auto,
                fetch_format: :auto,
                loading: "lazy",
                decoding: "async",
                class: "aspect-square h-full w-full object-cover",
                alt: @product.name %>
            </button>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Infos produit -->
    <div class="lg:sticky lg:top-6 h-fit">
      <% if @product.category.present? %>
        <p class="text-sm font-medium uppercase tracking-wide text-gray-400">
          <%= @product.category.name %>
        </p>
      <% end %>

      <h1 class="mt-2 text-3xl font-bold text-gray-900">
        <%= @product.name %>
      </h1>

      <p class="mt-4 text-3xl font-black text-gray-900">
        <%= number_to_currency(@product.price_cents / 100.0, unit: "€") %>
      </p>

      <% if @product.product_quantity_prices.any? %>
        <div class="mt-4 rounded-xl border border-green-200 bg-green-50 p-4">
          <p class="text-sm font-semibold text-green-900">
            Prix dégressifs
          </p>

          <div class="mt-2 space-y-1 text-sm text-green-800">
            <% @product.product_quantity_prices.order(:min_quantity).each do |tier| %>
              <div class="flex items-center justify-between">
                <span>
                  <%= tier.min_quantity %>+ exemplaires
                </span>

                <span class="font-semibold">
                  <%= number_to_currency(
                    tier.unit_price_cents / 100.0,
                    unit: "€"
                  ) %> / unité
                </span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="mt-6 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500">
          <%= t(".description")%>
        </h2>

        <div class="mt-3 prose prose-sm max-w-none text-gray-600">
          <p><%= markdown(@product.description) %></p>
        </div>
      </div>

      <div class="mt-6 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-500">
            Disponibilité
          </span>

          <span class="rounded-full border px-3 py-1 text-sm font-medium <%= product_availability_badge_class(@product) %>">
            <%= product_availability_label(@product) %>
          </span>
        </div>

        <% if @product.ready_to_ship? && @product.stock_quantity.positive? %>
          <p class="mt-3 text-sm text-gray-600">
            <strong><%= @product.stock_quantity %></strong>
            disponible<%= "s" if @product.stock_quantity > 1 %>.
            Expédition rapide sous 24 à 48h.
          </p>

        <% elsif @product.made_to_order? %>
          <p class="mt-3 text-sm text-gray-600">
            Fabriqué à la commande pour garantir une adaptation à votre besoin.
          </p>

        <% else %>
          <p class="mt-3 text-sm text-red-600">
            Temporairement indisponible.
          </p>
        <% end %>
      </div>

          <%= form_with url: cart_items_path, method: :post, local: true, class: "mt-8 space-y-6" do |f| %>
            <%= hidden_field_tag :product_id, @product.id %>

            <% if @custom_fields.any? %>
              <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
                <h2 class="text-lg font-semibold text-gray-900">
                  <%= t('.info')%>
                </h2>

                <p class="mt-1 text-sm text-gray-500">
                  <%= t('.info_desc')%>
                </p>

                <div class="mt-6 space-y-4">
                  <% @custom_fields.each do |custom_field| %>
                    <div>
                      <label class="block text-sm font-medium text-gray-700">
                        <%= custom_field.label %>
                        <% if custom_field.required? %>
                          <span class="text-red-500">*</span>
                        <% end %>
                      </label>

                      <% field_name = "custom_fields[#{custom_field.id}]" %>

                      <% case custom_field.field_type %>
                      <% when "textarea" %>
                        <%= text_area_tag field_name,
                          nil,
                          placeholder: custom_field.placeholder,
                          required: custom_field.required?,
                          rows: 4,
                          class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>

                      <% when "number" %>
                        <%= number_field_tag field_name,
                          nil,
                          placeholder: custom_field.placeholder,
                          required: custom_field.required?,
                          class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>

                      <% when "checkbox" %>
                        <label class="mt-2 flex items-center gap-2 text-sm text-gray-700">
                          <%= check_box_tag field_name, "1", false, class: "rounded border-gray-300 text-gray-900 focus:ring-gray-900" %>
                          <%= t('.yes')%>
                        </label>

                      <% else %>
                        <%= text_field_tag field_name,
                          nil,
                          placeholder: custom_field.placeholder,
                          required: custom_field.required?,
                          class: "mt-1 block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm focus:border-gray-900 focus:outline-none" %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          <div class="mt-6">          
            <%= button_to cart_items_path(product_id: @product),
              method: :post,
              form_class: "hidden sm:block",
              class: "cursor-pointer inline-flex w-full items-center justify-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" do %>
              <%= t('.add') %>
            <% end %>
          </div>
        <% end %>
        <p class="mt-4 text-xs leading-5 text-gray-500">
          <%= t(".subtitle")%>
        </p>
      </div>
    </div>
  </div>
</div>

<%# JSON-LD %>
<% product_schema = {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": @product.name,
    "description": strip_tags(@product.description.to_s),
    "image": @product.images.map { |image|
      cl_image_path(
        image.key,
        width: 1200,
        height: 1200,
        crop: :fill,
        quality: "auto",
        fetch_format: "auto"
      )
    },
    "brand": {
      "@type": "Brand",
      "name": "OPS3D"
    },
    "offers": {
      "@type": "Offer",
      "url": product_url(@product, locale: I18n.locale),
      "priceCurrency": "EUR",
      "price": format("%.2f", @product.price_cents / 100.0),
      "availability": @product.available? ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
      "itemCondition": "https://schema.org/NewCondition"
    }
  }
%>

<% breadcrumb_schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs_for(@product).each_with_index.map do |item, index|
    {
      "@type": "ListItem",
      "position": index + 1,
      "name": item[:name],
      "item": item[:url]
    }
  end
}
%>

<% content_for :head do %>
  <script type="application/ld+json" nonce="<%= content_security_policy_nonce %>">
    <%= json_escape(product_schema.to_json).html_safe %>
  </script>

  <script type="application/ld+json" nonce="<%= content_security_policy_nonce %>">
    <%= json_escape(breadcrumb_schema.to_json).html_safe %>
  </script>
<% end %>
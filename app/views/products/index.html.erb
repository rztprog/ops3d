<div class="px-4 py-10">
  <div class="mb-8 flex items-end justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= t(".title") %></h1>
      <p class="mt-2 text-sm text-gray-500">
        <%= t(".subtitle") %>     
      </p>
    </div>

    <p class="text-sm text-gray-500">
      <%= pluralize(@products.count, t(".product")) %>
    </p>
  </div>

  <% if @products.empty? %>
    <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
      <h2 class="text-xl font-semibold text-gray-900">Aucun produit disponible</h2>
      <p class="mt-2 text-gray-500">Le catalogue sera bientôt en ligne.</p>
    </div>
  <% else %>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      <% @products.each do |product| %>
        <div class="group flex h-full flex-col overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
          <%= link_to product_path(product), class: "block" do %>
            <div class="aspect-[4/3] overflow-hidden bg-gray-100">
              <% if product.images.attached? %>
                <%= image_tag product.images.first,
                  class: "h-full w-full object-cover transition duration-500 group-hover:scale-105" %>
              <% else %>
                <div class="flex h-full w-full items-center justify-center text-sm text-gray-400">
                  Pas d'image
                </div>
              <% end %>
            </div>
          <% end %>

          <div class="flex flex-1 flex-col p-5">
            <% if product.category.present? %>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gray-400">
                <%= product.category.name %>
              </p>
            <% end %>

            <h3 class="mt-3 text-xl font-bold text-gray-900">
              <%= link_to product.name, product_path(product), class: "hover:text-[color:var(--light)]" %>
            </h3>

            <p class="mt-2 line-clamp-2 text-sm leading-6 text-gray-500">
              <%= truncate(product.description.to_s, length: 90) %>
            </p>

            <div class="mt-auto pt-6 flex items-center justify-between gap-4">
              <p class="text-2xl font-black text-gray-900">
                <%= number_to_currency(product.price_cents / 100.0, unit: "€") %>
              </p>

              <%= button_to cart_items_path(product_id: product.id),
                method: :post,
                form_class: "hidden sm:block",
                class: "cursor-pointer rounded-xl bg-[color:var(--dark)] px-4 py-2 text-sm font-medium text-white hover:bg-[color:var(--light)]" do %>
                Ajouter
              <% end %>

              <div class="flex sm:hidden">
                <%= button_to cart_items_path(product_id: product.id),
                  method: :post,
                  class: "flex h-11 w-11 items-center justify-center rounded-full bg-[color:var(--dark)] text-white" do %>
                  <i class="fa-solid fa-plus"></i>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
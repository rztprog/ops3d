<% content_for :title, "Catalogue impression 3D personnalisée - OPS3D" %>
<% content_for :description,
  "Découvrez notre catalogue d'objets personnalisés en impression 3D. Produits sur mesure, qualité professionnelle et fabrication précise." %>
<% breadcrumbs = [
  breadcrumb_home,
  breadcrumb_item("Produits", products_url(locale: I18n.locale))
] %>

<div class="py-10">
  <%= render "shared/breadcrumbs", items: breadcrumbs %>
  <div class="mb-8 flex items-end justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= t(".title") %></h1>
      <div class="max-w-2xl">
        <p class="mt-3 text-sm text-gray-600 leading-relaxed">
          <%= t(".subtitle").html_safe %>
        </p>
      </div>
    </div>

    <p class="text-sm text-gray-500">
      <%= pluralize(@products.count, t(".product")) %>
    </p>
  </div>

  <% if @products.empty? %>
    <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
      <h2 class="text-xl font-semibold text-gray-900">Aucun produit disponible</h2>
      <p class="mt-2 text-gray-500">Le catalogue sera bientôt en ligne.</p>
    </div>
  <% else %>
    <div class="grid grid-cols-2 gap-3 sm:gap-6 lg:grid-cols-4">
      <% @products.each do |product| %>
        <div class="group flex h-full flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg sm:rounded-3xl">
          <%= link_to product_path(product), class: "block", aria: { label: product.name } do %>
            <div class="relative aspect-square overflow-hidden bg-gray-100 sm:aspect-[4/3]">
              <div class="absolute right-3 top-3 z-10">
                <span class="inline-flex rounded-full border px-3 py-1 text-xs font-medium shadow-sm backdrop-blur <%= product_availability_badge_class(product) %>">
                  <%= product_availability_label(product) %>
                </span>
              </div>
              <% if product.images.attached? %>
                <%= cl_image_tag product.images.first.key,
                  width: 292,
                  height: 292,
                  crop: :fill,
                  gravity: :auto,
                  quality: :auto,
                  fetch_format: :webp,
                  loading: "lazy",
                  decoding: "async",
                  alt: product.name,
                  class: "h-full w-full object-cover transition duration-500 group-hover:scale-105" %>
              <% else %>
                <div class="flex h-full w-full items-center justify-center text-sm text-gray-400">
                  Pas d'image
                </div>
              <% end %>
            </div>
          <% end %>

          <div class="flex flex-1 flex-col p-3 sm:p-5">
            <% if product.category.present? %>
              <p class="hidden text-xs font-semibold uppercase tracking-[0.18em] text-gray-700 sm:block">
                <%= product.category.name %>
              </p>
            <% end %>

            <h3 class="line-clamp-2 text-sm font-bold leading-snug text-gray-900 sm:mt-3 sm:text-xl">
              <%= link_to product.name, product_path(product), class: "hover:text-[color:var(--light)]" %>
            </h3>

            <p class="mt-2 hidden line-clamp-2 text-sm leading-6 text-gray-500 sm:block">
              <%= truncate(
                product.description.to_s
                  .gsub(/[#*_`>\-\[\]\(\)]/, ""),
                length: 90
              ) %>
            </p>

            <div class="mt-auto flex items-center justify-between gap-2 pt-3 sm:gap-4 sm:pt-6">
              <p class="text-base font-black text-gray-900 sm:text-2xl">
                <%= number_to_currency(product.price_cents / 100.0, unit: "€") %>
              </p>

              <%= button_to cart_items_path(product_id: product.id),
                method: :post,
                form_class: "hidden sm:block",
                class: "cursor-pointer rounded-xl bg-[color:var(--dark)] px-4 py-2 text-sm font-medium text-white hover:bg-[color:var(--light)]" do %>
                Ajouter
              <% end %>

              <div class="flex sm:hidden">
                <%= button_to cart_items_path(product_id: product.id),
                  method: :post,
                  class: "flex h-11 w-11 items-center justify-center rounded-full bg-[color:var(--dark)] text-white" do %>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 512 512"
                    class="w-4 h-4 text-white fill-current"
                  >
                    <g transform="translate(0.000000,512.000000) scale(0.100000,-0.100000)">
                      <path d="M2400 3920 l0 -1200 -1200 0 -1200 0 0 -160 0 -160 1200 0 1200 0 0
                      -1200 0 -1200 160 0 160 0 0 1200 0 1200 1200 0 1200 0 0 160 0 160 -1200 0
                      -1200 0 0 1200 0 1200 -160 0 -160 0 0 -1200z"/>
                    </g>
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
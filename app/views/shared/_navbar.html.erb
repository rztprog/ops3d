<nav class="text-[color:var(--dark)] bg-white border-b border-gray-200">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">

      <!-- Navigation -->
      <div class="flex">
         <%= link_to "Accueil", root_path,
            class: "hover:text-[color:var(--light)] pr-3 py-2 rounded-md text-sm font-medium" %>

        <%= link_to "Produits", products_path,
            class: "hover:text-[color:var(--light)] px-3 py-2 rounded-md text-sm font-medium" %>
      </div>

      <!-- Logo -->
      <div class="flex items-center">
        <%= link_to "OPS3D", root_path, class: "text-5xl black-ops-one" %>
      </div>

      <!-- Auth -->
      <div class="flex items-center gap-4">

        <!-- PANIER -->
        <%= link_to cart_path,
          class: "relative font-medium hover:text-[color:var(--light)] cursor-pointer" do %>
          <i class="fa-solid fa-cart-shopping fa-xl"></i>
          <% if current_cart && current_cart.cart_items.any? %>
            <span class="absolute -top-2 -right-3 bg-red-500 text-white text-xs px-2 py-0.5 rounded-full">
              <%= current_cart.cart_items.sum(:quantity) %>
            </span>
          <% end %>
        <% end %>

        <% if user_signed_in? %>

          <span class="hidden sm:block hover:text-[color:var(--light)] cursor-pointer">
            <i class="fa-solid fa-user fa-xl"></i>
          </span>

          <!-- ADMIN BUTTON -->
          <% if current_user.admin? %>
            <%= link_to "Admin",
              admin_root_path,
              class: "rounded-lg bg-[color:var(--dark)] px-4 py-2 text-sm font-medium text-white hover:bg-[color:var(--light)] transition cursor-pointer" %>
          <% end %>

          <%= button_to "Déconnexion",
              destroy_user_session_path,
              method: :delete,
              class: "text-sm hover:text-[color:var(--light)] cursor-pointer" %>

        <% else %>

          <%= link_to "Connexion",
              new_user_session_path,
              class: "text-sm hover:text-[color:var(--light)] cursor-pointer" %>

          <!-- CTA -->
          <%= link_to "S'inscrire",
              new_user_registration_path,
              class: "rounded-lg bg-[color:var(--dark)] px-4 py-2 text-sm font-medium text-white hover:[color:var(--light)] transition cursor-pointer" %>

        <% end %>
      </div>

    </div>
  </div>
</nav>
<nav class="border-b border-gray-200 bg-white text-[color:var(--dark)]" data-controller="navbar">
  <div class="mx-auto container px-4">
    <div class="flex h-16 items-center justify-between">

      <!-- LEFT DESKTOP -->
      <div class="hidden md:flex items-center gap-6">
        <%= link_to t('navbar.home'), root_path,
          class: "text-sm font-medium hover:text-[color:var(--light)]" %>

        <%= link_to t('navbar.products'), products_path,
          class: "text-sm font-medium hover:text-[color:var(--light)]" %>
      </div>

      <!-- MOBILE LEFT -->
      <div class="flex md:hidden items-center gap-3">
        <%= link_to cart_path,
          class: "relative font-medium hover:text-[color:var(--light)]",
          aria: { label: t('navbar.seeCart') } do %>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 512 512"
              class="w-9 h-9 fill-current"
            >
            <g transform="translate(0.000000,512.000000) scale(0.100000,-0.100000)">
              <path d="M4140 5005 c0 -2 -27 -133 -60 -290 -33 -157 -60 -288 -60 -290 0 -3
                -904 -5 -2010 -5 -1106 0 -2010 -1 -2010 -3 0 -7 371 -2265 376 -2290 l6 -27
                1574 0 1574 0 -5 -22 c-3 -13 -21 -99 -41 -193 -19 -93 -37 -180 -41 -192 l-5
                -23 -1459 0 -1459 0 0 -170 0 -170 1589 0 c1047 0 1592 3 1596 10 5 8 705
                3321 705 3336 0 2 160 4 355 4 l355 0 0 165 0 165 -490 0 c-269 0 -490 -2
                -490 -5z"/>
              <path d="M636 988 c-123 -16 -261 -110 -319 -216 -147 -271 10 -598 312 -653
              168 -30 352 52 445 199 76 121 88 289 28 416 -85 183 -266 281 -466 254z"/>
              <path d="M3286 989 c-133 -19 -273 -121 -329 -241 -99 -210 -32 -440 166 -569
              214 -139 514 -50 627 186 60 123 53 294 -16 411 -38 65 -122 142 -189 174 -54
              26 -83 33 -175 44 -14 1 -52 -1 -84 -5z"/>
            </g>
          </svg>
          <% if current_cart && current_cart.cart_items.any? %>
            <span class="absolute -top-2 -right-3 rounded-full bg-red-500 px-2 py-0.5 text-xs text-white">
              <%= current_cart.cart_items.sum(:quantity) %>
            </span>
          <% end %>
        <% end %>
      </div>

      <!-- LOGO -->
      <div class="flex items-center">
        <%= link_to "OPS3D", root_path, class: "black-ops-one text-4xl sm:text-4xl tracking-wide" %>
      </div>

      <!-- RIGHT DESKTOP -->
      <div class="hidden md:flex items-center gap-4">

        <%= link_to cart_path,
          class: "relative inline-flex items-center justify-center hover:text-[color:var(--light)] transition-colors",
            aria: { label: t('navbar.seeCart') } do %>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 512 512"
              class="w-7 h-7 fill-current"
            >
              <g transform="translate(0.000000,512.000000) scale(0.100000,-0.100000)">
              <path d="M4140 5005 c0 -2 -27 -133 -60 -290 -33 -157 -60 -288 -60 -290 0 -3
                -904 -5 -2010 -5 -1106 0 -2010 -1 -2010 -3 0 -7 371 -2265 376 -2290 l6 -27
                1574 0 1574 0 -5 -22 c-3 -13 -21 -99 -41 -193 -19 -93 -37 -180 -41 -192 l-5
                -23 -1459 0 -1459 0 0 -170 0 -170 1589 0 c1047 0 1592 3 1596 10 5 8 705
                3321 705 3336 0 2 160 4 355 4 l355 0 0 165 0 165 -490 0 c-269 0 -490 -2
                -490 -5z"/>
                <path d="M636 988 c-123 -16 -261 -110 -319 -216 -147 -271 10 -598 312 -653
                168 -30 352 52 445 199 76 121 88 289 28 416 -85 183 -266 281 -466 254z"/>
                <path d="M3286 989 c-133 -19 -273 -121 -329 -241 -99 -210 -32 -440 166 -569
                214 -139 514 -50 627 186 60 123 53 294 -16 411 -38 65 -122 142 -189 174 -54
                26 -83 33 -175 44 -14 1 -52 -1 -84 -5z"/>
              </g>
            </svg>
          <% if current_cart && current_cart.cart_items.any? %>
            <span class="absolute -top-2 -right-3 rounded-full bg-red-500 px-2 py-0.5 text-xs text-white">
              <%= current_cart.cart_items.sum(:quantity) %>
            </span>
          <% end %>
        <% end %>

        <% unless user_signed_in? %>
          <%= link_to guest_orders_path,
            class: "text-sm font-medium hover:text-[color:var(--light)]",
            aria: { label: t('navbar.guest') } do %>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 512 512"
              class="w-7 h-7 fill-current"
            >
              <g transform="translate(0.000000,512.000000) scale(0.100000,-0.100000)">
                <path d="M2385 5106 c-232 -39 -409 -118 -583 -262 -276 -227 -432 -557 -432
                -912 0 -549 357 -1016 885 -1158 408 -109 846 9 1146 308 320 320 433 805 287
                1232 -115 337 -404 626 -738 739 -173 59 -403 80 -565 53z"/>
                <path d="M2030 2560 c-352 -26 -671 -160 -935 -394 -214 -189 -388 -475 -460
                -756 -45 -173 -47 -203 -52 -817 l-5 -593 1982 0 1982 0 -5 593 c-5 614 -7
                644 -52 817 -57 221 -171 438 -328 621 -224 262 -553 447 -906 511 -106 19
                -160 21 -616 23 -275 2 -547 0 -605 -5z"/>
              </g>
            </svg>
          <% end %>
        <% end %>

        <% if user_signed_in? %>
          <%= link_to account_path,
            class: "hidden sm:block relative inline-flex items-center justify-center hover:text-[color:var(--light)] transition-colors cursor-pointer" do %>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 512 512"
                class="w-7 h-7 fill-current"
              >
                <g transform="translate(0.000000,512.000000) scale(0.100000,-0.100000)">
                  <path d="M2385 5106 c-232 -39 -409 -118 -583 -262 -276 -227 -432 -557 -432
                  -912 0 -549 357 -1016 885 -1158 408 -109 846 9 1146 308 320 320 433 805 287
                  1232 -115 337 -404 626 -738 739 -173 59 -403 80 -565 53z"/>
                  <path d="M2030 2560 c-352 -26 -671 -160 -935 -394 -214 -189 -388 -475 -460
                  -756 -45 -173 -47 -203 -52 -817 l-5 -593 1982 0 1982 0 -5 593 c-5 614 -7
                  644 -52 817 -57 221 -171 438 -328 621 -224 262 -553 447 -906 511 -106 19
                  -160 21 -616 23 -275 2 -547 0 -605 -5z"/>
                </g>
              </svg>
          <% end %>

          <% if current_user.admin? %>
            <%= link_to "Admin",
              admin_root_path,
              class: "rounded-lg bg-[color:var(--dark)] px-4 py-2 text-sm font-medium text-white transition hover:bg-[color:var(--light)]" %>
          <% end %>

          <%= button_to t('navbar.logout'),
            destroy_user_session_path,
            method: :delete,
            class: "cursor-pointer text-sm hover:text-[color:var(--light)]" %>
        <% else %>
          <%= link_to t('navbar.connection'),
            new_user_session_path,
            class: "text-sm hover:text-[color:var(--light)]" %>

          <%= link_to t('navbar.signon'),
            new_user_registration_path,
            class: "rounded-lg bg-[color:var(--dark)] px-4 py-2 text-sm font-medium text-white transition hover:bg-[color:var(--light)]" %>
        <% end %>
        <%= render "shared/locale_dropdown" %>
      </div>

      <!-- MOBILE BURGER -->
      <div class="flex md:hidden items-center">
        <button
          type="button"
          data-action="click->navbar#toggle"
          class="inline-flex items-center justify-center rounded-md p-2 hover:bg-gray-100 hover:text-[color:var(--light)]">
          <span class="sr-only"><%= t('navbar.menu') %></span>

          <svg data-navbar-target="openIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="h-9 w-9">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>

          <svg data-navbar-target="closeIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="hidden h-9 w-9">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- MOBILE MENU -->
    <div data-navbar-target="menu" class="hidden border-t border-gray-200 py-4 md:hidden">
      <div class="flex flex-col gap-3">
        <%= render "shared/locale_dropdown" %>
        <%= link_to t('navbar.home'), root_path,
          class: "rounded-lg px-3 py-2 text-xl font-medium hover:bg-gray-100 hover:text-[color:var(--light)]" %>

        <%= link_to t('navbar.products'), products_path,
          class: "rounded-lg px-3 py-2 text-xl font-medium hover:bg-gray-100 hover:text-[color:var(--light)]" %>

        <%= link_to t('navbar.cart'), cart_path,
          class: "rounded-lg px-3 py-2 text-xl font-medium hover:bg-gray-100 hover:text-[color:var(--light)]" %>

        <% unless user_signed_in? %>
          <%= link_to t('navbar.guest'), guest_orders_path,
            class: "rounded-lg px-3 py-2 text-xl font-medium hover:bg-gray-100 hover:text-[color:var(--light)]" %>
        <% end %>

        <% if user_signed_in? %>
          <%= link_to t('navbar.account'), account_path,
          class: "rounded-lg px-3 py-2 text-xl font-medium hover:bg-gray-100 hover:text-[color:var(--light)]" %>

          <% if current_user.admin? %>
            <%= link_to "Administration",
              admin_root_path,
              class: "rounded-lg bg-[color:var(--dark)] px-3 py-2 text-xl font-medium text-white hover:bg-[color:var(--light)]" %>
          <% end %>

          <%= button_to t('navbar.logout'),
            destroy_user_session_path,
            method: :delete,
            class: "w-full rounded-lg px-3 py-2 text-left text-xl font-medium hover:bg-gray-100 hover:text-[color:var(--light)]" %>
        <% else %>
          <%= link_to t('navbar.connection'),
            new_user_session_path,
            class: "rounded-lg px-3 py-2 text-xl font-medium hover:bg-gray-100 hover:text-[color:var(--light)]" %>

          <%= link_to t('navbar.signon'),
            new_user_registration_path,
            class: "rounded-lg bg-[color:var(--dark)] px-3 py-2 text-xl font-medium text-white hover:bg-[color:var(--light)]" %>
        <% end %>
      </div>
    </div>
  </div>
</nav>
<footer class="border-t border-gray-200 bg-white text-[color:var(--dark)]">
  <div class="mx-auto container px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <%= link_to "OPS3D", root_path, class: "text-3xl black-ops-one tracking-wide" %>

        <p class="mt-4 max-w-sm text-sm leading-6 text-gray-600">
          <%= t('footer.text')%>
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wide text-[color:var(--dark)]">
          Navigation
        </h3>

        <ul class="mt-4 space-y-3 text-sm text-gray-600">
          <li>
            <%= link_to t('navbar.home'), root_path, class: "hover:text-[color:var(--light)]" %>
          </li>
          <li>
            <%= link_to t('navbar.products'), products_path, class: "hover:text-[color:var(--light)]" %>
          </li>
          <li>
            <%= link_to t('navbar.cart'), cart_path, class: "hover:text-[color:var(--light)]" %>
          </li>
        </ul>
      </div>

      <!-- Account / Contact -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wide text-[color:var(--dark)]">
          <%= t('footer.account') %>
        </h3>

        <ul class="mt-4 space-y-3 text-sm text-gray-600">
          <% if user_signed_in? %>
            <li>
              <%= link_to t('navbar.account'), edit_user_registration_path, class: "hover:text-[color:var(--light)]" %>
            </li>
            <% if current_user.admin? %>
              <li>
                <%= link_to "Administration", admin_root_path, class: "hover:text-[color:var(--light)]" %>
              </li>
            <% end %>
          <% else %>
            <li>
              <%= link_to t('navbar.connection'), new_user_session_path, class: "hover:text-[color:var(--light)]" %>
            </li>
            <li>
              <%= link_to t('navbar.signon'), new_user_registration_path, class: "hover:text-[color:var(--light)]" %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-3 border-t border-gray-200 pt-6 text-sm text-gray-500 md:flex-row md:items-center md:justify-between">
      <p>© <%= Time.current.year %> OPS3D. <%= t('footer.right') %>.</p>

      <div class="flex flex-wrap items-center gap-4">
        <%= link_to "Mentions légales", legal_path, class: "hover:text-[color:var(--light)]" %>
        <%= link_to "CGV", terms_path, class: "hover:text-[color:var(--light)]" %>
        <%= link_to "FAQ", faq_path, class: "hover:text-[color:var(--light)]" %>
        <%= link_to "Contact", contact_path, class: "hover:text-[color:var(--light)]" %>
      </div>
    </div>
  </div>
</footer>
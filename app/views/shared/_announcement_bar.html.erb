<% settings = Ops3dSetting.first %>

<% if settings&.announcement_enabled? && settings.announcement_text.present? %>
  <div class="overflow-hidden bg-yellow-400 text-[color:var(--dark)]">
    <div class="marquee-track py-4 text-xl font-bold">
      <% 3.times do |index| %>
        <div class="marquee-content" <%= "aria-hidden=true" if index.positive? %>>
          <span><%= settings.announcement_text %></span>

          <% if settings.announcement_link_url.present? && settings.announcement_link_label.present? %>
            <%= link_to settings.announcement_link_label,
              settings.announcement_link_url,
              class: "ml-4 underline underline-offset-4 text-[color:var(--light)] hover:text-[color:var(--dark)]" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
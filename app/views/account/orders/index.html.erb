<div class="mx-auto container px-4 py-10">
  <div class="mb-8 flex items-end justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= t(".title") %> (<%= @orders.count()%>)</h1>
      <p class="mt-2 text-sm text-gray-500">
        <%= t('.subtitle') %>
      </p>
    </div>

    <%= link_to t('.back'),
      account_path,
      class: "text-sm font-medium text-[color:var(--light)] hover:underline" %>
  </div>

  <% if @orders.any? %>
    <div class="hidden sm:block overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500"><%= t('.order') %></th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500"><%= t('.date') %></th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500"><%= t('.status') %></th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500"><%= t('.amount') %></th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-200 bg-white">
          <% @orders.each do |order| %>
            <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='<%= account_order_path(order) %>'">
              <td class="px-6 py-4 font-medium text-gray-900">
                #<%= order.id %>
              </td>

              <td class="px-6 py-4 text-sm text-gray-600">
                <%= l(order.created_at, format: :short) %>
              </td>

            <td class="px-6 py-4 text-sm">
              <span class="rounded-full px-3 py-1 text-xs font-medium <%= order_status_badge_class(order.status) %>">
                <%= order_status_label(order.status) %>
              </span>
            </td>

              <td class="px-6 py-4 text-sm font-medium text-gray-900">
                <%= number_to_currency(order.total_price_cents / 100.0, unit: "€") %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="space-y-4 sm:hidden">
        <% @orders.each do |order| %>
          <%= link_to account_order_path(order),
            class: "block rounded-2xl border border-gray-200 bg-white p-5 shadow-sm hover:bg-gray-50 transition" do %>

            <div class="flex items-center justify-between">
              <p class="font-medium text-gray-900">
                #<%= order.id %>
              </p>

              <span class="rounded-full px-3 py-1 text-xs font-medium <%= order_status_badge_class(order.status) %>">
                <%= order_status_label(order.status) %>
              </span>
            </div>

            <p class="mt-2 text-sm text-gray-500">
              <%= l(order.created_at, format: :short) %>
            </p>

            <div class="mt-3 flex items-center justify-between">
              <p class="font-semibold text-gray-900">
                <%= number_to_currency(order.total_price_cents / 100.0, unit: "€") %>
              </p>

              <i class="fa-solid fa-chevron-right text-xs text-gray-400"></i>
            </div>

          <% end %>
        <% end %>
      </div>
  <% else %>
    <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
      <h2 class="text-xl font-semibold text-gray-900"><%= t('.empty') %></h2>
      <p class="mt-2 text-gray-500"><%= t('.noOrder') %></p>

      <div class="mt-6">
        <%= link_to t('.all'),
          products_path,
          class: "inline-flex items-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>
      </div>
    </div>
  <% end %>
</div>
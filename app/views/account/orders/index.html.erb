<div class="mx-auto container px-4 py-10">
  <div class="mb-8 flex items-end justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Mes commandes</h1>
      <p class="mt-2 text-sm text-gray-500">
        Historique de toutes tes commandes.
      </p>
    </div>

    <%= link_to "Retour au compte",
      account_path,
      class: "text-sm font-medium text-[color:var(--light)] hover:underline" %>
  </div>

  <% if @orders.any? %>
    <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Commande</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Date</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Statut</th>
            <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Montant</th>
            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Action</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-200 bg-white">
          <% @orders.each do |order| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 font-medium text-gray-900">
                #<%= order.id %>
              </td>

              <td class="px-6 py-4 text-sm text-gray-600">
                <%= l(order.created_at, format: :short) %>
              </td>

              <td class="px-6 py-4 text-sm text-gray-700">
                <%= order_status_label(order.status) %>
              </td>

              <td class="px-6 py-4 text-sm font-medium text-gray-900">
                <%= number_to_currency(order.total_price_cents / 100.0, unit: "€") %>
              </td>

              <td class="px-6 py-4 text-right">
                <%= link_to "Voir",
                  account_order_path(order),
                  class: "text-sm font-medium text-[color:var(--light)] hover:underline" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
      <h2 class="text-xl font-semibold text-gray-900">Aucune commande</h2>
      <p class="mt-2 text-gray-500">Tu n'as encore rien commandé.</p>

      <div class="mt-6">
        <%= link_to "Voir les produits",
          products_path,
          class: "inline-flex items-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>
      </div>
    </div>
  <% end %>
</div>
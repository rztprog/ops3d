<div class="mx-auto container px-4 py-10">
  <div class="mb-8 flex flex-col gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= t('.title') %> #<%= @order.id %></h1>
      <div class="flex items-end justify-between">
        <p class="mt-2 text-sm text-gray-500">
          <%= t('.placed') %> <%= l(@order.created_at, format: :long) %>
        </p>
        <%= link_to "← Retour aux commandes",
        account_orders_path,
        class: "text-sm font-medium text-[color:var(--light)] hover:underline" %>
      </div>
    </div>
  </div>

  <% case @order.status %>
  <% when "pending" %>
    <div class="rounded-2xl border border-yellow-200 bg-yellow-50 p-6 mb-8">
      <h2 class="text-lg font-semibold text-yellow-800">
        <%= t('.pending') %>
      </h2>
      <p class="mt-2 text-sm text-yellow-700">
        <%= t('.pending_text') %>
      </p>
    </div>

  <% when "paid" %>
    <div class="rounded-2xl border border-green-200 bg-green-50 p-6 mb-8">
      <h2 class="text-lg font-semibold text-green-800">
        <%= t('.paid') %>
      </h2>
      <p class="mt-2 text-sm text-green-700">
        <%= t('.paid_text') %>
      </p>
    </div>

  <% when "in_preparation" %>
    <div class="rounded-2xl border border-blue-200 bg-blue-50 p-6 mb-8">
      <h2 class="text-lg font-semibold text-blue-800">
        <%= t('.prep') %>
      </h2>
      <p class="mt-2 text-sm text-blue-700">
        <%= t('.prep_text') %>
      </p>
    </div>

  <% when "shipped" %>
    <div class="rounded-2xl border border-green-200 bg-green-50 p-6 mb-8">
      <h2 class="text-lg font-semibold text-green-800">
        <%= t('.shipped') %>
      </h2>
      <p class="mt-2 text-sm text-green-700">
        <%= t('.shipped_text') %>
      </p>
    </div>

  <% when "cancelled" %>
    <div class="rounded-2xl border border-red-200 bg-red-50 p-6 mb-8">
      <h2 class="text-lg font-semibold text-red-800">
        <%= t('.cancelled') %>
      </h2>
      <p class="mt-2 text-sm text-red-700">
        <%= t('.cancelled_text') %>
      </p>
    </div>
  <% end %>
  <div class="grid grid-cols-1 gap-8 xl:grid-cols-3">
    <div class="xl:col-span-2 space-y-8">
      <div class="rounded-2xl border border-gray-200 bg-white shadow-sm">
        <div class="border-b border-gray-200 px-6 py-4">
          <h2 class="text-lg font-semibold text-gray-900"><%= t('.ordered') %></h2>
        </div>

        <div class="divide-y divide-gray-200">
          <% @order.order_items.each do |item| %>
            <div class="flex items-center justify-between gap-4 px-6 py-4">
              <div>
                <p class="font-medium text-gray-900"><%= item.product_name %></p>
                <p class="text-sm text-gray-500"><%= t('.quantity') %> : <%= item.quantity %></p>
              </div>

              <div class="text-right">
                <p class="text-sm text-gray-500">
                  <%= number_to_currency(item.unit_price_cents / 100.0, unit: "€") %> / <%= t('.unit') %>
                </p>
                <p class="font-medium text-gray-900">
                  <%= number_to_currency((item.unit_price_cents * item.quantity) / 100.0, unit: "€") %>
                </p>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-gray-900"><%= t('.address') %></h2>

        <div class="mt-4 text-sm leading-6 text-gray-600">
          <p><%= t('.name') %> : <%= @order.first_name %> <%= @order.last_name %></p>
          <p><%= t('.line') %> : <%= @order.address_line %></p>
          <p><%= t('.postal') %> : <%= @order.postal_code %></p>
          <p><%= t('.city') %> : <%= @order.city %></p>
          <p><%= t('.country') %> : <%= @order.country %></p>
          <p class="mt-2"><%= t('.email') %> : <%= @order.email %></p>
        </div>
      </div>
    </div>

    <div class="space-y-8">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-gray-900"><%= t('.summary') %></h2>

        <dl class="mt-4 space-y-4 text-sm">
          <div class="flex items-center justify-between gap-4">
            <dt class="text-gray-500"><%= t('.status') %></dt>
            <dd class="rounded-full px-3 py-1 text-xs font-medium <%= order_status_badge_class(order.status) %>"><%= order_status_label(@order.status) %></dd>
          </div>

          <div class="flex items-center justify-between gap-4">
            <dt class="text-gray-500"><%= t('.subtotal') %></dt>
            <dd class="font-medium text-gray-900">
              <%= number_to_currency(@order.subtotal_price_cents / 100.0, unit: "€") %>
            </dd>
          </div>

          <div class="flex items-center justify-between gap-4">
            <dt class="text-gray-500"><%= t('.fee') %></dt>
            <dd class="font-medium text-gray-900">
              <%= number_to_currency(@order.shipping_price_cents / 100.0, unit: "€") %>
            </dd>
          </div>

          <div class="border-t border-gray-200 pt-4 flex items-center justify-between gap-4">
            <dt class="font-semibold text-gray-900"><%= t('.total') %></dt>
            <dd class="font-semibold text-gray-900">
              <%= number_to_currency(@order.total_price_cents / 100.0, unit: "€") %>
            </dd>
          </div>
        </dl>
      </div>
      <% if @order.status == 'pending' %>
        <%= button_to checkout_order_path(@order),
          method: :post,
          data: { turbo: false },
          class: "cursor-pointer w-full flex items-center justify-center gap-3 rounded-xl bg-indigo-600 px-6 py-4 text-sm font-semibold text-white shadow-md transition hover:bg-indigo-500 hover:shadow-lg active:scale-[0.98]" do %>
          
          <!-- Icône carte -->
          <svg version="1.0" xmlns="http://www.w3.org/2000/svg"
            width="18.000000pt" height="18.000000pt" viewBox="0 0 512.000000 512.000000"
            preserveAspectRatio="xMidYMid meet">

            <g transform="translate(0.000000,512.000000) scale(0.100000,-0.100000)"
            fill="#fff" stroke="none">
            <path d="M525 4363 c-249 -34 -458 -227 -511 -473 -20 -97 -20 -2563 0 -2660
            48 -219 206 -387 432 -457 56 -17 149 -18 2114 -18 1967 0 2058 1 2115 18 84
            26 181 79 242 132 91 79 170 221 193 344 14 75 14 2548 0 2623 -24 126 -103
            266 -197 347 -55 47 -153 101 -233 128 -53 17 -140 18 -2090 19 -1119 1 -2048
            -1 -2065 -3z m4107 -320 c66 -30 132 -95 159 -156 22 -47 24 -68 27 -239 l4
            -188 -2262 0 -2262 0 4 188 c3 170 5 192 26 237 40 88 125 157 213 174 24 5
            944 8 2044 7 l2000 -1 47 -22z m188 -1033 l0 -150 -2260 0 -2260 0 0 150 0
            150 2260 0 2260 0 0 -150z m-2 -1087 l-3 -638 -24 -52 c-27 -61 -93 -126 -159
            -156 l-47 -22 -2025 0 -2025 0 -47 22 c-66 30 -132 95 -159 156 l-24 52 -3
            638 -3 637 2261 0 2261 0 -3 -637z"/>
            <path d="M757 1803 c-4 -3 -7 -71 -7 -150 l0 -143 755 0 755 0 0 150 0 150
            -748 0 c-412 0 -752 -3 -755 -7z"/>
            <path d="M3467 1803 c-4 -3 -7 -71 -7 -150 l0 -143 150 0 150 0 0 150 0 150
            -143 0 c-79 0 -147 -3 -150 -7z"/>
            <path d="M4070 1660 l0 -150 150 0 151 0 -3 148 -3 147 -147 3 -148 3 0 -151z"/>
            </g>
            </svg>

          <span><%= t('.stripe')%></span>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
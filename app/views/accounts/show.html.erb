<div class="mx-auto max-w-7xl px-4 py-10">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Mon compte</h1>
    <p class="mt-2 text-sm text-gray-500">
      Retrouve ici tes informations et tes dernières commandes.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
    <!-- Sidebar -->
    <div class="lg:col-span-1">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-gray-900">Profil</h2>

        <div class="mt-4 space-y-3 text-sm text-gray-600">
          <p>
            <span class="font-medium text-gray-900">Nom :</span>
            <%= [current_user.first_name, current_user.last_name].join(" ") %>
          </p>

          <p>
            <span class="font-medium text-gray-900">Email :</span>
            <%= current_user.email %>
          </p>
        </div>

        <div class="mt-6 flex flex-col gap-3">
          <%= link_to "Modifier mes informations",
            edit_user_registration_path,
            class: "inline-flex items-center justify-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>

          <%= link_to "Voir toutes mes commandes",
            account_orders_path,
            class: "inline-flex items-center justify-center rounded-xl border border-gray-300 px-5 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
        </div>
      </div>
    </div>

    <!-- Main -->
    <div class="lg:col-span-2">
      <div class="rounded-2xl border border-gray-200 bg-white shadow-sm">
        <div class="border-b border-gray-200 px-6 py-4">
          <h2 class="text-lg font-semibold text-gray-900">Dernières commandes</h2>
        </div>

        <% if @orders.any? %>
          <div class="divide-y divide-gray-200">
            <% @orders.each do |order| %>
              <div class="flex flex-col gap-4 px-6 py-5 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <p class="font-medium text-gray-900">Commande #<%= order.id %></p>
                  <p class="mt-1 text-sm text-gray-500">
                    Passée le <%= l(order.created_at, format: :short) %>
                  </p>
                </div>

                <div class="flex items-center gap-4">
                  <p class="text-sm font-medium text-gray-900">
                    <%= number_to_currency(order.total_price_cents / 100.0, unit: "€") %>
                  </p>

                  <%= link_to "Voir",
                    account_order_path(order),
                    class: "text-sm font-medium text-[color:var(--light)] hover:underline" %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-10 text-center">
            <p class="text-gray-500">Tu n'as encore passé aucune commande.</p>

            <div class="mt-4">
              <%= link_to "Découvrir les produits",
                products_path,
                class: "inline-flex items-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
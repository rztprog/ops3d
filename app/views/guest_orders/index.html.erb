<h1>Mes commandes</h1>

<div class="mb-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
  Pour retrouver tes commandes sur tous tes appareils, crée un compte avec la même adresse email.
</div>

<% if @orders.any? %>
  <% @orders.each do |order| %>
    <%= link_to order_path(order),
      class: "block rounded-2xl border border-gray-200 bg-white p-5 shadow-sm hover:bg-gray-50" do %>
      <div class="flex items-center justify-between">
        <div>
          <p class="font-semibold text-gray-900">Commande #<%= order.id %></p>
          <p class="text-sm text-gray-500"><%= l(order.created_at, format: :short) %></p>
        </div>

        <div class="text-right">
          <p class="font-semibold text-gray-900">
            <%= number_to_currency(order.total_price_cents / 100.0, unit: "€") %>
          </p>
          <p class="text-sm text-gray-500"><%= order.status %></p>
        </div>
      </div>
    <% end %>
  <% end %>
<% else %>
  <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
    <p class="text-gray-500">Aucune commande invitée sur cet appareil.</p>
  </div>
<% end %>
<div class="mx-auto py-10">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">
      <%= t('.orders') %>
    </h1>

    <p class="mt-2 text-sm text-gray-500">
      <%= t('.back') %>
    </p>
  </div>

  <div class="mb-8 rounded-2xl border border-amber-200 bg-amber-50 p-5 shadow-sm <%= order_status_badge_class("pending") %>">
    <div class="flex items-start gap-3">
      <div class="mt-0.5 text-amber-600">
        ⚠
      </div>

      <div>
        <h2 class="font-bold text-amber-900">
          <%= t('.advice') %>
        </h2>

        <p class="mt-1 text-sm leading-6 text-amber-800">
          <%= t('.description') %>
        </p>

        <div class="mt-4">
          <%= link_to t('.account'),
            new_user_registration_path,
            class: "inline-flex items-center rounded-xl bg-[color:var(--dark)] px-4 py-2 text-sm font-medium text-white hover:bg-[color:var(--light)]" %>
        </div>
      </div>
    </div>
  </div>

  <% if @orders.any? %>
    <div class="space-y-4">
      <% @orders.each do |order| %>
        <%= link_to order_path(order),
          class: "block rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:border-gray-300 hover:shadow-md" do %>

          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900">
                <%= t('.order') %> #<%= order.id %>
              </h2>

              <p class="mt-1 text-sm text-gray-500">
                <%= l(order.created_at, format: :short) %>
              </p>
            </div>

            <div class="text-left sm:text-right">
              <p class="text-lg font-semibold text-gray-900">
                <%= number_to_currency(
                  order.total_price_cents / 100.0,
                  unit: "€"
                ) %>
              </p>

              <span class="mt-2 inline-flex rounded-full px-3 py-1 text-xs font-medium <%= order_status_badge_class(order.status) %>">
                <%= order_status_label(order.status) %>
              </span>
            </div>
          </div>

        <% end %>
      <% end %>
    </div>

  <% else %>

    <div class="rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
      <h2 class="text-xl font-semibold text-gray-900">
        Aucune commande trouvée
      </h2>

      <p class="mt-2 text-gray-500">
        Aucune commande invitée n'est enregistrée sur cet appareil.
      </p>

      <div class="mt-6">
        <%= link_to "Voir les produits",
          products_path,
          class: "inline-flex items-center rounded-xl bg-gray-900 px-5 py-3 text-sm font-medium text-white hover:bg-gray-700" %>
      </div>
    </div>

  <% end %>
</div>